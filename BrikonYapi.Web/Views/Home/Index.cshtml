@model BrikonYapi.Web.Models.ViewModels.HomeViewModel
@using BrikonYapi.Web.Data.Entities
@{
    bool isEn = ViewBag.IsEn == true;
    ViewData["Title"] = isEn ? "Home" : "Ana Sayfa";
    ViewData["BodyClass"] = "has-dark-hero";
    var phone    = Model.Settings.GetValueOrDefault("PhoneNumber","") ?? "";
    var email    = Model.Settings.GetValueOrDefault("Email","") ?? "";
    var address  = Model.Settings.GetValueOrDefault("Address","") ?? "";
    var slogan   = Model.Settings.GetValueOrDefault("CompanySlogan","Geleceği İnşa Ediyoruz") ?? "";
    var about    = Model.Settings.GetValueOrDefault("AboutText","Brikon Yapı olarak kaliteli inşaat hizmetleri sunuyoruz.") ?? "";
    ViewBag.Phone    = phone;
    ViewBag.Email    = email;
    ViewBag.Address  = address;
    ViewBag.AboutText= about;
    ViewBag.Instagram= Model.Settings.GetValueOrDefault("Instagram","");
    ViewBag.Facebook = Model.Settings.GetValueOrDefault("Facebook","");
    ViewBag.LinkedIn = Model.Settings.GetValueOrDefault("LinkedIn","");
    bool marqueeVideoMode = (Model.Settings.GetValueOrDefault("MarqueeMode","image") ?? "image") == "video";
}

<!-- ═════════════════════════════════════════════════════
     HERO
     ═════════════════════════════════════════════════════ -->
@{
  var igUrl = Model.Settings.GetValueOrDefault("Instagram","") ?? "";
  var fbUrl = Model.Settings.GetValueOrDefault("Facebook","") ?? "";
  var liUrl = Model.Settings.GetValueOrDefault("LinkedIn","") ?? "";

  // Açılış ekranındaki projeler: IsFeatured = true olanlar
  // Yoksa varsayılan iki video
  var heroProjects = Model.HeroProjects;
  var firstTitle   = heroProjects.Any() ? heroProjects[0].Name : "Brikon Yapı";
}
<section id="hero">

  <!-- Arka Plan: Her proje için video veya görsel -->
  <div class="hero-videos">
    @if (heroProjects.Any())
    {
      @for (int i = 0; i < heroProjects.Count; i++)
      {
        var p = heroProjects[i];
        if (!string.IsNullOrEmpty(p.VideoPath))
        {
          <video class="hero-video @(i==0?"active":"")" autoplay muted loop playsinline preload="auto">
            <source src="@p.VideoPath" type="video/mp4" />
          </video>
        }
        else if (!string.IsNullOrEmpty(p.MainImagePath))
        {
          <div class="hero-video @(i==0?"active":"")"
               style="background:url('@p.MainImagePath') center/cover no-repeat"></div>
        }
        else
        {
          <div class="hero-video @(i==0?"active":"")"
               style="background:linear-gradient(135deg,#1a1918 0%,#2B2A29 100%)"></div>
        }
      }
    }
    else
    {
      <video class="hero-video active" autoplay muted loop playsinline preload="auto">
        <source src="/videos/hero1.mp4" type="video/mp4" />
      </video>
      <video class="hero-video" autoplay muted loop playsinline preload="auto">
        <source src="/videos/hero2.mp4" type="video/mp4" />
      </video>
    }
  </div>

  <!-- Karartma -->
  <div class="hero-overlay"></div>



  <!-- Orta içerik -->
  <div class="hero-center">
    @if (heroProjects.Any())
    {
      @for (int i = 0; i < heroProjects.Count; i++)
      {
        var p = heroProjects[i];
        var loc = string.Join(" • ", new[]{ p.District, p.City }.Where(x => !string.IsNullOrEmpty(x)));
        <div class="hero-slide @(i==0?"active":"")">
          @if (!string.IsNullOrEmpty(loc)) { <div class="hero-eyebrow">@loc</div> }
          <h1 class="hero-title">@p.Name</h1>
          <a href="/Projeler/@p.Slug" class="btn-hero">@(isEn ? "View Project" : "Proje Sayfası")</a>
        </div>
      }
    }
    else
    {
      <div class="hero-slide active in">
        <div class="hero-eyebrow">Brikon Yapı</div>
        <h1 class="hero-title">@slogan</h1>
        <a href="/Projeler" class="btn-hero">@(isEn ? "Our Projects" : "Projelerimiz")</a>
      </div>
    }
  </div>

  <!-- Progress bar -->
  <div class="hero-progress"><div class="hero-progress-fill" id="hero-progress-fill"></div></div>

  <!-- Alt Tab Şeridi (sadece metin, görsel yok) -->
  <div class="hero-tabs" id="hero-tabs">
    @if (heroProjects.Any())
    {
      @for (int i = 0; i < heroProjects.Count; i++)
      {
        var p = heroProjects[i];
        var tabLoc = string.Join(" • ", new[]{ p.District, p.City }.Where(x => !string.IsNullOrEmpty(x)));
        <button class="hero-tab @(i==0?"active":"")" data-idx="@i">
          @if (!string.IsNullOrEmpty(p.MainImagePath))
          {
            <img class="tab-bg-img" src="@p.MainImagePath" alt="" />
          }
          <div class="tab-info">
            @if (!string.IsNullOrEmpty(tabLoc)) { <span class="tab-loc">@tabLoc</span> }
            <span class="tab-name">@p.Name</span>
          </div>
        </button>
      }
    }
  </div>

</section>


<!-- ═════════════════════════════════════════════════════
     HAKKIMIZDA
     ═════════════════════════════════════════════════════ -->
<section id="about" class="section">
  <div class="container">
    <div class="about-grid">

      <!-- Görsel tarafı -->
      <div class="about-img-wrap reveal-left">
        @if (Model.OngoingProjects.Any() && !string.IsNullOrEmpty(Model.OngoingProjects[0].MainImagePath))
        {
          <img class="about-img-main" src="@Model.OngoingProjects[0].MainImagePath" alt="Brikon Yapı" />
        }
        else
        {
          <div class="about-img-main" style="background:linear-gradient(135deg,var(--c-primary) 0%,var(--c-secondary) 100%);aspect-ratio:4/3;"></div>
        }
        <div class="about-accent-box">
          <div class="about-accent-num">2005</div>
          <div class="about-accent-lbl">@(isEn ? "Since 2005" : "2005'ten Bu Yana")</div>
        </div>
      </div>

      <!-- Metin tarafı -->
      <div class="reveal-right">
        <div class="sh">
          <p class="sh-eyebrow">@(isEn ? "About Us" : "Hakkımızda")</p>
          <h2 class="sh-title">@(isEn ? "A Trusted " : "Güvenilir Bir ")<span>@(isEn ? "Construction Partner" : "Yapı Ortağı")</span></h2>
          <div class="sh-line"></div>
        </div>
        <p style="font-size:.98rem;line-height:1.85;color:#555;margin-bottom:1.25rem">@about</p>
        <p style="font-size:.98rem;line-height:1.85;color:#555;margin-bottom:2rem">
          @(isEn ? "In every project, we prioritize quality materials, on-time delivery and customer satisfaction. We combine modern architectural aesthetics with functionality to enhance quality of life." : "Her projemizde kaliteli malzeme kullanımı, zamanında teslimat ve müşteri memnuniyetini ön planda tutuyoruz. Modern mimarinin estetik anlayışını, işlevsellikle birleştirerek yaşam kalitesini artırıyoruz.")
        </p>
        <div class="about-values">
          <div class="about-value reveal delay-1">
            <div class="av-icon">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div>
              <div class="av-name">@(isEn ? "Quality Assurance" : "Kalite Güvencesi")</div>
              <div class="av-desc">@(isEn ? "Production compliant with TSE and ISO standards" : "TSE ve ISO standartlarına uygun üretim")</div>
            </div>
          </div>
          <div class="about-value reveal delay-2">
            <div class="av-icon">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <div class="av-name">@(isEn ? "On-Time Delivery" : "Zamanında Teslimat")</div>
              <div class="av-desc">@(isEn ? "Complete delivery on promised dates" : "Söz verilen tarihlerde eksiksiz teslim")</div>
            </div>
          </div>
          <div class="about-value reveal delay-3">
            <div class="av-icon">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/></svg>
            </div>
            <div>
              <div class="av-name">@(isEn ? "Expert Team" : "Uzman Kadro")</div>
              <div class="av-desc">@(isEn ? "Experienced engineers and craftsmen" : "Deneyimli mühendis ve usta ekibi")</div>
            </div>
          </div>
          <div class="about-value reveal delay-4">
            <div class="av-icon">
              <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <div class="av-name">@(isEn ? "Sustainability" : "Sürdürülebilirlik")</div>
              <div class="av-desc">@(isEn ? "Eco-friendly and energy-efficient buildings" : "Çevre dostu ve enerji verimli yapılar")</div>
            </div>
          </div>
        </div>
        <a href="/Projeler" class="btn btn-primary">@(isEn ? "View Projects" : "Projelerimizi İnceleyin")</a>
      </div>
    </div>
  </div>
</section>

<!-- ── Tek Dalga Geçiş ── -->
<div style="line-height:0;background:#fff;">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 80" preserveAspectRatio="none" style="display:block;width:100%;height:80px;">
    <defs>
      <linearGradient id="accentLine" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%"   stop-color="#0f1724" stop-opacity="0"/>
        <stop offset="20%"  stop-color="#0082B4" stop-opacity="1"/>
        <stop offset="80%"  stop-color="#0082B4" stop-opacity="1"/>
        <stop offset="100%" stop-color="#0f1724" stop-opacity="0"/>
      </linearGradient>
    </defs>
    <!-- Dalga dolgusu -->
    <path d="M0,0 C360,80 1080,0 1440,60 L1440,80 L0,80 Z" fill="#0f1724"/>
    <!-- Accent çizgisi — dalganın üst kenarı boyunca -->
    <path d="M0,0 C360,80 1080,0 1440,60" fill="none" stroke="url(#accentLine)" stroke-width="2"/>
  </svg>
</div>

<!-- ═════════════════════════════════════════════════════
     PROJELERİMİZ — auto-scroll marquee
     ═════════════════════════════════════════════════════ -->
<section id="home-projects">
<style>
#home-projects { background:#0f1724; padding:3.5rem 0 3rem; overflow:hidden; }

.hp-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:nowrap; gap:1rem; padding:0 3rem 2.2rem; overflow:hidden; }
.hp-eyebrow { font-size:.58rem; font-weight:700; letter-spacing:.3em; text-transform:uppercase; color:var(--c-primary); display:block; margin-bottom:.4rem; }
.hp-title { font-family:'Inter',sans-serif; font-weight:900; font-size:clamp(1.4rem,2.2vw,2rem); color:#fff; letter-spacing:-.025em; margin:0; }
.hp-viewall {
    font-size:.6rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase;
    color:rgba(255,255,255,.35); text-decoration:none; flex-shrink:0;
    display:flex; align-items:center; gap:.4rem; transition:color .2s; white-space:nowrap;
}
.hp-viewall:hover { color:var(--c-primary); }
.hp-viewall-line { display:block; width:20px; height:1.5px; background:currentColor; transition:width .25s; flex-shrink:0; }
.hp-viewall:hover .hp-viewall-line { width:32px; }

/* Marquee wrapper */
.hp-marquee-outer {
    position:relative;
    overflow:hidden;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
}
.hp-marquee-track {
    display:flex;
    gap:3px;
    width:max-content;
    animation: hp-scroll 180s linear infinite;
    will-change: transform;
    cursor: grab;
}
.hp-marquee-track:hover  { animation-play-state: paused; }
.hp-marquee-track:active { cursor: grabbing; }

@@keyframes hp-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* Card */
.hp-card {
    flex-shrink:0;
    width: 240px;
    height: 340px;
    position:relative; overflow:hidden;
    background:#080d14;
    text-decoration:none; display:block;
    border-radius:3px;
    transition: transform .35s cubic-bezier(.4,0,.2,1);
}
.hp-video {
    position:absolute; inset:0; width:100%; height:100%;
    object-fit:cover; display:block; opacity:0;
    transition:opacity .6s ease;
    z-index:1;
}
.hp-img { transition:opacity .6s ease; }
.hp-card.playing .hp-video { opacity:1; }
.hp-card.playing .hp-img   { opacity:0; }
.hp-card:hover { transform: translateY(-5px); }

.hp-img {
    position:absolute; inset:0; width:100%; height:100%;
    object-fit:cover; display:block;
    transition:transform .65s cubic-bezier(.4,0,.2,1), filter .4s;
}
.hp-card:hover .hp-img { transform:scale(1.08); filter:brightness(.52) saturate(1.1); }

.hp-grad {
    position:absolute; inset:0;
    background:linear-gradient(to bottom, transparent 30%, rgba(0,0,0,.92) 100%);
    z-index:2;
}
.hp-line {
    position:absolute; top:0; left:0; right:0; height:3px;
    background:var(--c-primary); z-index:8;
    transform:scaleX(0); transform-origin:left;
    transition:transform .4s cubic-bezier(.4,0,.2,1);
}
.hp-card:hover .hp-line { transform:scaleX(1); }

.hp-card::before {
    content:''; position:absolute; inset:0; z-index:7; pointer-events:none;
    box-shadow:inset 0 0 0 0 rgba(0,130,180,0); transition:box-shadow .3s;
    border-radius:3px;
}
.hp-card:hover::before { box-shadow:inset 0 0 0 1.5px rgba(0,130,180,.6); }

.hp-chip {
    position:absolute; top:.8rem; right:.8rem; z-index:6;
    font-size:.5rem; font-weight:700; color:rgba(255,255,255,.9);
    background:rgba(0,0,0,.55); backdrop-filter:blur(8px);
    padding:.22rem .6rem; border-radius:2px; border:1px solid rgba(255,255,255,.12);
}
.hp-badge {
    position:absolute; top:.8rem; left:.8rem; z-index:6;
    font-size:.48rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
    padding:.22rem .6rem; border-radius:2px; color:#fff;
}
.hp-badge-ongoing   { background:var(--c-primary); }
.hp-badge-completed { background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15); backdrop-filter:blur(4px); }

.hp-body { position:absolute; bottom:0; left:0; right:0; z-index:5; padding:1rem .95rem .9rem; }
.hp-name {
    font-family:'Inter',sans-serif; font-weight:800; font-size:.86rem;
    color:#fff; line-height:1.3; margin:0 0 .22rem;
    text-shadow:0 2px 8px rgba(0,0,0,.5);
    transition:transform .32s cubic-bezier(.4,0,.2,1);
    overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;
}
.hp-card:hover .hp-name { transform:translateY(-3px); }
.hp-loc {
    display:flex; align-items:center; gap:.24rem;
    font-size:.62rem; color:rgba(255,255,255,.42);
    transition:transform .32s .04s cubic-bezier(.4,0,.2,1);
    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
}
.hp-card:hover .hp-loc { transform:translateY(-3px); }

@@media(max-width:768px){
    .hp-header { padding:0 1.3rem 1.8rem; }
    .hp-viewall-line { display:none; }
    .hp-marquee-outer {
        -webkit-mask-image: none;
        mask-image: none;
    }
    .hp-marquee-track { animation: none !important; cursor: grab; }
    .hp-marquee-track:active { cursor: grabbing; }
    .hp-card { width: 72vw; height: 260px; }
    .hp-pass2 { display: flex; }
}
@@media(max-width:480px){
    .hp-card { width: 78vw; height: 240px; }
}
</style>

  <!-- Header -->
  <div class="hp-header">
    <div>
      <span class="hp-eyebrow">@(isEn?"Portfolio":"Portföy")</span>
      <h2 class="hp-title">@(isEn?"Our Projects":"Projelerimiz")</h2>
    </div>
    <a href="/Projeler" class="hp-viewall">
      <span class="hp-viewall-line"></span>
      @(isEn?"All Projects":"Tüm Projeler")
    </a>
  </div>

  <!-- Marquee -->
  <div class="hp-marquee-outer">
    <div class="hp-marquee-track" id="hp-marquee-track">
      @* Kartları iki kez render et — desktop sonsuz döngü için. Mobilde 2. set CSS ile gizlenir *@
      @for (int pass = 0; pass < 2; pass++)
      {
        @foreach (var p in Model.AllProjects.Where(x => x.IsMarquee))
        {
          bool isOngoing = p.Status == ProjectStatus.Ongoing;
          bool hasVid     = !string.IsNullOrEmpty(p.VideoPath);
          bool autoVideo  = hasVid;
          <a href="/Projeler/@p.Slug"
             class="hp-card @(hasVid?"hp-has-video":"") @(autoVideo?"hp-autoplay":"") @(pass==1?"hp-pass2":"")"
             data-video="@(hasVid?p.VideoPath:"")">
            @if (!string.IsNullOrEmpty(p.MainImagePath))
            { <img src="@p.MainImagePath" alt="@p.Name" loading="@(autoVideo?"eager":"lazy")" class="hp-img" /> }
            else { <div style="position:absolute;inset:0;background:linear-gradient(160deg,#1a2540,#0d1520)"></div> }
            @if (hasVid) { <video class="hp-video" muted loop playsinline preload="@(autoVideo?"auto":"none")"></video> }
            <div class="hp-grad"></div>
            <div class="hp-line"></div>
            <span class="hp-badge @(isOngoing ? "hp-badge-ongoing" : "hp-badge-completed")">
              @(isEn ? (isOngoing ? "Ongoing" : "Completed") : (isOngoing ? "Devam Ediyor" : "Tamamlandı"))
            </span>
            @if (!string.IsNullOrEmpty(p.CardTag)) { <span class="hp-chip">@p.CardTag</span> }
            <div class="hp-body">
              <div class="hp-name">@p.Name</div>
              @if (!string.IsNullOrEmpty(p.Location))
              { <div class="hp-loc"><svg width="9" height="9" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>@p.Location</div> }
            </div>
          </a>
        }
      }
    </div>
  </div>

</section>

<!-- ═════════════════════════════════════════════════════
     HARİTA
     ═════════════════════════════════════════════════════ -->
<section id="map-section">
  <!-- Sol panel -->
  <div class="map-left-panel">
    <p class="map-ol-eyebrow">@(isEn ? "Locations" : "Lokasyonlar")</p>
    <h2 class="map-ol-title">@(isEn ? "Project Map" : "Proje Haritası")</h2>

    <!-- Filtre -->
    <div class="map-filter-row">
      <button class="map-filter-btn active" data-filter="all">@(isEn ? "All" : "Tümü")</button>
      <button class="map-filter-btn" data-filter="Ongoing">@(isEn ? "Ongoing" : "Devam Eden")</button>
      <button class="map-filter-btn" data-filter="Completed">@(isEn ? "Completed" : "Tamamlanan")</button>
    </div>

    <!-- Proje listesi -->
    <div class="map-project-list" id="map-project-list">
      @{
        var allMapProjects = Model.OngoingProjects.Concat(Model.CompletedProjects).ToList();
      }
      @foreach (var p in allMapProjects)
      {
        <div class="map-proj-item @(p.Latitude.HasValue && p.Longitude.HasValue ? "has-coords" : "")"
             data-lat="@p.Latitude" data-lng="@p.Longitude" data-slug="@p.Slug"
             data-status="@p.Status.ToString()">
          <span class="map-proj-dot @(p.Status == ProjectStatus.Ongoing ? "dot-ongoing" : "dot-completed")"></span>
          <div class="map-proj-info">
            <span class="map-proj-name">@p.Name</span>
            @if (!string.IsNullOrEmpty(p.City))
            {
              <span class="map-proj-city">@(string.IsNullOrEmpty(p.District) ? p.City : p.District + ", " + p.City)</span>
            }
          </div>
          <svg class="map-proj-arrow" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        </div>
      }
    </div>

    <!-- İstatistik -->
    <div class="map-stats-row">
      <div class="map-stat">
        <span class="map-stat-val">@Model.OngoingProjects.Count</span>
        <span class="map-stat-lbl">@(isEn ? "Ongoing" : "Devam Eden")</span>
      </div>
      <div class="map-stat-div"></div>
      <div class="map-stat">
        <span class="map-stat-val">@Model.CompletedProjects.Count</span>
        <span class="map-stat-lbl">@(isEn ? "Completed" : "Tamamlanan")</span>
      </div>
    </div>

    <!-- Tile switcher -->
    <div class="map-tile-row">
      <button class="tile-btn active" data-tile="light" title="@(isEn?"Light":"Açık")">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        @(isEn ? "Light" : "Açık")
      </button>
      <button class="tile-btn" data-tile="dark" title="@(isEn?"Dark":"Koyu")">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        @(isEn ? "Dark" : "Koyu")
      </button>
