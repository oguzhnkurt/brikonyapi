@section Scripts {
<script>
/* ── Mobil marquee: transform tabanlı otomatik kayma + dokunuşla sürükleme ── */
(function(){
  if(window.innerWidth > 768) return;
  var track = document.getElementById('hp-marquee-track');
  if(!track) return;

  var offset      = 0;      /* mevcut translateX (negatif = sağa kaymış) */
  var speed       = 0.35;   /* piksel/frame otomatik kayma hızı */
  var paused      = false;
  var resumeTimer = null;
  var touchStartX = 0;
  var touchStartOffset = 0;

  function halfWidth(){ return track.scrollWidth / 2; }

  function clamp(x){
    var w = halfWidth();
    /* -w ile 0 arasında tut, seamless döngü */
    x = x % (-w);
    if(x > 0) x -= w;
    return x;
  }

  function apply(){ track.style.transform = 'translateX(' + offset + 'px)'; }

  function tick(){
    if(!paused){
      offset = clamp(offset - speed);
      apply();
    }
    requestAnimationFrame(tick);
  }

  track.addEventListener('touchstart', function(e){
    paused = true;
    if(resumeTimer) clearTimeout(resumeTimer);
    touchStartX      = e.touches[0].clientX;
    touchStartOffset = offset;
  }, { passive: true });

  track.addEventListener('touchmove', function(e){
    var dx = e.touches[0].clientX - touchStartX;
    offset = clamp(touchStartOffset + dx);
    apply();
  }, { passive: true });

  track.addEventListener('touchend', function(){
    resumeTimer = setTimeout(function(){ paused = false; }, 600);
  }, { passive: true });

  apply();
  requestAnimationFrame(tick);
})();

/* ── Kart videoları (per-kart ayar) ── */
(function(){
  var canHover = window.matchMedia('(hover:hover) and (pointer:fine)').matches;
  document.querySelectorAll('.hp-card.hp-has-video').forEach(function(card){
    var video    = card.querySelector('.hp-video');
    var src      = card.dataset.video;
    var autoplay = card.classList.contains('hp-autoplay');
    if(!video || !src) return;

    if(autoplay){
      /* Kart bazında: görünür olunca otomatik oynat */
      var obs = new IntersectionObserver(function(entries){
        entries.forEach(function(e){
          if(e.isIntersecting){
            if(!video.src){ video.src = src; }
            video.play().catch(function(){});
            card.classList.add('playing');
          } else {
            video.pause();
            card.classList.remove('playing');
          }
        });
      }, { threshold: 0.3 });
      obs.observe(card);
    } else if(canHover){
      /* Sadece hover'da oynat */
      card.addEventListener('mouseenter', function(){
        if(!video.src){ video.src = src; }
        video.play().catch(function(){});
        card.classList.add('playing');
      });
      card.addEventListener('mouseleave', function(){
        card.classList.remove('playing');
        video.pause();
        video.currentTime = 0;
      });
    }
  });
})();


(function(){
  var isEn = @(isEn ? "true" : "false");

  var allProjects = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.OngoingProjects.Concat(Model.CompletedProjects)
      .Select(p => new {
        name       = p.Name,
        slug       = p.Slug,
        lat        = p.Latitude,
        lng        = p.Longitude,
        image      = p.MainImagePath,
        video      = p.VideoPath,
        images     = p.Images.OrderBy(i => i.OrderIndex).Select(i => i.ImagePath).ToList(),
        city       = p.City,
        district   = p.District,
        unitCount  = p.UnitCount,
        floorCount = p.FloorCount,
        totalArea  = p.TotalArea,
        desc       = p.ShortDescription,
        status     = p.Status.ToString()
      })
  ));

  /* ── Harita ── */
  var map = L.map('home-map', { zoomControl:false, scrollWheelZoom:false });
  L.control.zoom({ position:'bottomright' }).addTo(map);

  setTimeout(function(){ map.invalidateSize(); }, 200);
  window.addEventListener('resize', function(){ map.invalidateSize(); });

  map.getContainer().addEventListener('mouseenter', function(){ map.scrollWheelZoom.enable(); });
  map.getContainer().addEventListener('mouseleave', function(){ map.scrollWheelZoom.disable(); });

  /* ── Tile katmanları ── */
  var tileLayers = {
    light: L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution:'© <a href="https://carto.com/">CARTO</a>',
      subdomains:'abcd', maxZoom:19
    }),
    dark: L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution:'© <a href="https://carto.com/">CARTO</a>',
      subdomains:'abcd', maxZoom:19
    }),
    sat: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution:'© Esri', maxZoom:18
    })
  };
  var currentTile = 'light';
  tileLayers.light.addTo(map);

  /* ── Pin ikonu ── */
  function makePin(status, active) {
    if (status === 'Ongoing') {
      var selRing = active
        ? '<circle cx="15" cy="15" r="8.5" fill="none" stroke="white" stroke-width="2.5" opacity=".95"/>'
        : '';
      return L.divIcon({
        html: '<svg class="bk-pin-svg" width="30" height="38" viewBox="0 0 30 38"' +
              ' xmlns="http://www.w3.org/2000/svg" style="overflow:visible">' +
              '<circle class="bk-ring-1" cx="15" cy="15" r="14" fill="#0082B4"/>' +
              '<circle class="bk-ring-2" cx="15" cy="15" r="14" fill="#0082B4"/>' +
              '<path d="M15 38C15 38 0 24 0 15A15 15 0 1 1 30 15C30 24 15 38 15 38Z"' +
              ' fill="#0082B4" style="filter:drop-shadow(0 3px 7px rgba(0,130,180,.55))"/>' +
              '<circle cx="15" cy="15" r="5.5" fill="white" opacity=".95"/>' +
              selRing +
              '</svg>',
        className:'', iconSize:[30,38], iconAnchor:[15,38], popupAnchor:[0,-40]
      });
    } else {
      var filt = active
        ? 'drop-shadow(0 0 6px rgba(255,210,0,.95))'
        : 'drop-shadow(0 3px 6px rgba(0,0,0,.45))';
      return L.divIcon({
        html: '<svg class="bk-pin-svg" width="26" height="34" viewBox="0 0 26 34"' +
              ' xmlns="http://www.w3.org/2000/svg" style="filter:' + filt + '">' +
              '<path d="M13 34C13 34 0 22 0 13A13 13 0 1 1 26 13C26 22 13 34 13 34Z" fill="#1E293B"/>' +
              '<circle cx="13" cy="13" r="4.5" fill="white" opacity=".78"/>' +
              '</svg>',
        className:'', iconSize:[26,34], iconAnchor:[13,34], popupAnchor:[0,-36]
      });
    }
  }

  /* ── Cluster grubu ── */
  var currentFilter = 'all';
  var markers = {};
  var activeSlug = null;

  function buildClusterIcon(cluster) {
    var children = cluster.getAllChildMarkers();
    var hasOngoing   = children.some(function(m){ return m._bkStatus === 'Ongoing'; });
    var hasCompleted = children.some(function(m){ return m._bkStatus === 'Completed'; });
    var cls = hasOngoing && hasCompleted ? 'mixed' : (hasOngoing ? 'ongoing' : 'completed');
    return L.divIcon({
      html:'<div class="bk-cluster ' + cls + '"><span>' + cluster.getChildCount() + '</span></div>',
      className:'', iconSize:[40,40], iconAnchor:[20,20]
    });
  }

  var clusterGroup = L.markerClusterGroup({
    maxClusterRadius:60,
    spiderfyOnMaxZoom:true,
    showCoverageOnHover:false,
    zoomToBoundsOnClick:true,
    iconCreateFunction: buildClusterIcon,
    animate:true
  });

  /* ── Modal ── */
  var hmModal   = document.getElementById('hm-modal');
  var hmOverlay = document.getElementById('hm-overlay');

  function openHmPanel(p, marker) {
    if (activeSlug && markers[activeSlug]) {
      markers[activeSlug].marker.setIcon(makePin(markers[activeSlug].status, false));
    }
    activeSlug = p.slug;
    if (marker) marker.setIcon(makePin(p.status, true));

    // Slider
    var slides = document.getElementById('hm-slides');
    var dotsEl = document.getElementById('hm-dots');
    slides.innerHTML = '';
    dotsEl.innerHTML = '';

    // Görselleri topla: önce ana görsel, sonra sadece /web/ yolundaki galeriler, max 4
    var candidates = [];
    if (p.video) candidates.push({ type:'video', src:p.video });
    if (p.image) candidates.push({ type:'img', src:p.image });
    if (p.images && p.images.length) {
      // Önce /web/ klasöründeki kaliteli görselleri dene
      var webImgs = p.images.filter(function(src){ return src && src.indexOf('/web/') !== -1 && src !== p.image; });
      // /web/ yoksa tüm görselleri al
      var gallery = webImgs.length ? webImgs : p.images.filter(function(src){ return src && src !== p.image; });
      gallery.forEach(function(src){ candidates.push({ type:'img', src:src }); });
    }

    function buildSlider(items) {
      slides.innerHTML = '';
      dotsEl.innerHTML = '';
      var curSlide = 0;

      if (!items.length) {
        slides.innerHTML = '<div class="hm-slide"><div class="hm-modal-media-empty"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></div></div>';
        document.getElementById('hm-prev').style.display = 'none';
        document.getElementById('hm-next').style.display = 'none';
        dotsEl.style.display = 'none';
        return;
      }

      items.forEach(function(item, i) {
        var slide = document.createElement('div');
        slide.className = 'hm-slide';
        slide.innerHTML = item.type === 'video'
          ? '<video src="' + item.src + '" autoplay muted loop playsinline></video>'
          : '<img src="' + item.src + '" alt="' + p.name + ' ' + (i+1) + '">';
        slides.appendChild(slide);

        if (items.length > 1) {
          var dot = document.createElement('div');
          dot.className = 'hm-dot' + (i===0?' active':'');
          (function(idx){ dot.addEventListener('click', function(){ goSlide(idx); }); })(i);
          dotsEl.appendChild(dot);
        }
      });

      function goSlide(n) {
        curSlide = n;
        slides.style.transform = 'translateX(-' + (n * 100) + '%)';
        dotsEl.querySelectorAll('.hm-dot').forEach(function(d,i){ d.classList.toggle('active', i===n); });
        document.getElementById('hm-prev').style.opacity = n === 0 ? '.3' : '1';
        document.getElementById('hm-prev').style.pointerEvents = n === 0 ? 'none' : '';
        document.getElementById('hm-next').style.opacity = n === items.length-1 ? '.3' : '1';
        document.getElementById('hm-next').style.pointerEvents = n === items.length-1 ? 'none' : '';
      }

      document.getElementById('hm-prev').onclick = function(){ if(curSlide>0) goSlide(curSlide-1); };
      document.getElementById('hm-next').onclick = function(){ if(curSlide<items.length-1) goSlide(curSlide+1); };

      var showNav = items.length > 1;
      document.getElementById('hm-prev').style.display = showNav ? '' : 'none';
      document.getElementById('hm-next').style.display = showNav ? '' : 'none';
      dotsEl.style.display = showNav ? '' : 'none';
      goSlide(0);
    }

    buildSlider(candidates);

    // Badge
    var badge = document.getElementById('hm-panel-badge');
    badge.textContent = p.status === 'Ongoing' ? (isEn?'Ongoing':'Devam Ediyor') : (isEn?'Completed':'Tamamlandı');
    badge.className = 'hm-panel-badge ' + (p.status === 'Ongoing' ? 'ongoing' : 'completed');

    // İsim & lokasyon
    document.getElementById('hm-panel-name').textContent = p.name;
    var loc = [p.district, p.city].filter(Boolean).join(', ');
    var locEl = document.getElementById('hm-panel-location');
    if (loc) {
      locEl.innerHTML = '<svg width="12" height="12" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z"/></svg>' + loc;
      locEl.style.display = 'flex';
    } else { locEl.style.display = 'none'; }

    // Stats
    var s = '';
    if (p.unitCount)  s += '<div class="hm-pstat"><span class="hm-pstat-val">' + p.unitCount  + '</span><span class="hm-pstat-lbl">' + (isEn?'Units':'Daire')  + '</span></div>';
    if (p.floorCount) s += '<div class="hm-pstat"><span class="hm-pstat-val">' + p.floorCount + '</span><span class="hm-pstat-lbl">' + (isEn?'Floors':'Kat')    + '</span></div>';
    if (p.totalArea)  s += '<div class="hm-pstat"><span class="hm-pstat-val">' + (p.totalArea||0).toLocaleString() + '</span><span class="hm-pstat-lbl">m²</span></div>';
    var statsEl = document.getElementById('hm-panel-stats');
    statsEl.innerHTML = s;
    statsEl.style.display = s ? 'flex' : 'none';

    // Açıklama
    var descEl = document.getElementById('hm-panel-desc');
    if (p.desc) { descEl.textContent = p.desc; descEl.style.display = ''; }
    else { descEl.style.display = 'none'; }

    document.getElementById('hm-panel-link').href = '/Projeler/' + p.slug;

    hmOverlay.classList.add('active');
    hmModal.classList.add('open');
    document.body.style.overflow = 'hidden';
    highlightListItem(p.slug);
  }

  function closeHmPanel() {
    hmModal.classList.remove('open');
    hmOverlay.classList.remove('active');
    document.body.style.overflow = '';
    if (activeSlug && markers[activeSlug]) {
      markers[activeSlug].marker.setIcon(makePin(markers[activeSlug].status, false));
    }
    activeSlug = null;
    document.querySelectorAll('.map-proj-item').forEach(function(el){ el.classList.remove('active'); });
  }

  document.getElementById('hm-panel-close').addEventListener('click', closeHmPanel);
  hmOverlay.addEventListener('click', closeHmPanel);
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeHmPanel(); });

  function rebuildMarkers() {
    clusterGroup.clearLayers();
    markers = {};
    activeSlug = null;
    closeHmPanel();

    allProjects.forEach(function(p) {
      if (!p.lat || !p.lng) return;
      if (currentFilter !== 'all' && p.status !== currentFilter) return;

      var m = L.marker([p.lat, p.lng], { icon: makePin(p.status, false) });
      m._bkStatus = p.status;
      m.on('click', function(){ openHmPanel(p, m); });
      clusterGroup.addLayer(m);
      markers[p.slug] = { marker:m, status:p.status, data:p };
    });

    // Liste görünürlüğünü güncelle
    document.querySelectorAll('.map-proj-item').forEach(function(el) {
      var st = el.dataset.status;
      el.style.display = (currentFilter==='all' || st===currentFilter) ? '' : 'none';
    });
  }

  rebuildMarkers();
  map.addLayer(clusterGroup);

  /* ── Haritayı pinlere göre ortala ── */
  var allCoords = allProjects.filter(function(p){ return p.lat && p.lng; }).map(function(p){ return [p.lat, p.lng]; });
  if (allCoords.length > 0) {
    map.fitBounds(L.latLngBounds(allCoords), { padding:[50,50], maxZoom:12 });
  } else {
    map.setView([39.5,35], 6);
  }

  /* ── Sol liste highlight ── */
  function highlightListItem(slug) {
    document.querySelectorAll('.map-proj-item').forEach(function(el){ el.classList.remove('active'); });
    var el = document.querySelector('.map-proj-item[data-slug="' + slug + '"]');
    if (el) { el.classList.add('active'); el.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
  }

  /* ── Sol liste tıklama ── */
  document.querySelectorAll('.map-proj-item.has-coords').forEach(function(el) {
    el.addEventListener('click', function() {
      var slug = el.dataset.slug;
      var lat  = parseFloat(el.dataset.lat);
      var lng  = parseFloat(el.dataset.lng);
      map.flyTo([lat, lng], 14, { duration:1 });
      setTimeout(function(){
        if (markers[slug]) openHmPanel(markers[slug].data, markers[slug].marker);
      }, 900);
    });
  });

  /* ── Filtre butonları ── */
  document.querySelectorAll('.map-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.map-filter-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      rebuildMarkers();
    });
  });

  /* ── Tile switcher ── */
  document.querySelectorAll('.tile-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tile-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      map.removeLayer(tileLayers[currentTile]);
      currentTile = btn.dataset.tile;
      tileLayers[currentTile].addTo(map);
    });
  });

})();

// Süreç adımları — otomatik ilerleme + timer çubuğu
(function(){
  var steps       = Array.prototype.slice.call(document.querySelectorAll('.proc-step'));
  var detailText  = document.getElementById('proc-detail-text');
  var detailBgNum = document.getElementById('proc-detail-bg-num');
  var procSteps   = document.getElementById('proc-steps');
  if (!steps.length || !detailText) return;

  var AUTO_MS   = 4000;
  var activeIdx = 0;
  var autoTimer = null;
  var paused    = false;

  function setActive(idx) {
    activeIdx = idx;
    steps.forEach(function(s, i) {
      s.classList.toggle('active', i === idx);
      s.classList.toggle('passed', i < idx);
    });
    detailText.style.opacity = '0';
    if (detailBgNum) detailBgNum.style.opacity = '0';
    setTimeout(function(){
      detailText.textContent = steps[idx].dataset.detail || '';
      if (detailBgNum) detailBgNum.textContent = steps[idx].dataset.num || '';
      detailText.style.opacity = '1';
      if (detailBgNum) detailBgNum.style.opacity = '1';
    }, 160);
  }

  function scheduleNext() {
    clearTimeout(autoTimer);
    if (paused) return;
    autoTimer = setTimeout(function(){
      setActive((activeIdx + 1) % steps.length);
      scheduleNext();
    }, AUTO_MS);
  }

  // Hover → duraklat
  if (procSteps) {
    procSteps.addEventListener('mouseenter', function(){ paused = true; clearTimeout(autoTimer); });
    procSteps.addEventListener('mouseleave', function(){ paused = false; scheduleNext(); });
  }

  steps.forEach(function(step, i) {
    step.addEventListener('click', function(){
      setActive(i);
      scheduleNext();
    });
  });

  setActive(0);
  scheduleNext();
})();
</script>
}



