@{
    bool isEn = ViewBag.IsEn == true;
    ViewData["Title"]       = isEn ? "About Us" : "Hakkımızda";
    ViewData["Description"] = isEn
        ? "Brikon Yapı – Urban transformation and construction excellence since our foundation."
        : "Brikon Yapı – Kentsel dönüşüm ve inşaat alanında köklü deneyim.";
}

@section Styles {
<style>
/* ══ HERO ══════════════════════════════════════════════════ */
.ab-hero {
    position: relative;
    min-height: 100svh;
    display: flex; align-items: center;
    overflow: hidden;
    color: #fff;
    padding: 120px 0 80px;
}
.ab-hero-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    z-index: 0;
}
.ab-hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(
        135deg,
        rgba(5,12,25,.82) 0%,
        rgba(10,22,40,.70) 50%,
        rgba(5,12,25,.75) 100%
    );
}
.ab-hero-content { position: relative; z-index: 2; }

.ab-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .72rem; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: #f59e0b;
    margin-bottom: 18px;
}
.ab-eyebrow::before { content:''; width:28px; height:2px; background:#f59e0b; display:block; }
.ab-hero h1 {
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 900; line-height: 1.1;
    margin-bottom: 22px;
    letter-spacing: -.5px;
    text-shadow: 0 2px 20px rgba(0,0,0,.4);
}
.ab-hero h1 span { color: #f59e0b; }
.ab-hero p {
    font-size: 1.08rem; color: rgba(255,255,255,.7);
    max-width: 600px; line-height: 1.8; margin-bottom: 36px;
}
.ab-hero-badges { display: flex; gap: 12px; flex-wrap: wrap; }
.ab-badge {
    display: inline-flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.18);
    color: rgba(255,255,255,.9);
    padding: 9px 18px; border-radius: 50px;
    font-size: .8rem; font-weight: 600;
    backdrop-filter: blur(8px);
    transition: all .2s;
}
.ab-badge:hover { background: rgba(245,158,11,.2); border-color: #f59e0b; color: #f59e0b; }
.ab-badge iconify-icon { color: #f59e0b; font-size: 1rem; }

/* scroll indicator */
.ab-scroll {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: rgba(255,255,255,.4); font-size: .62rem; letter-spacing: 2px; text-transform: uppercase;
    animation: bounce 2s infinite;
}
.ab-scroll-line {
    width: 1px; height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,.3), transparent);
}
@@keyframes bounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(6px); }
}

/* ══ STATS ══════════════════════════════════════════════════ */
.ab-stats { background: #fff; border-bottom: 1px solid #f0f0f0; padding: 0; }
.ab-stats-inner {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-left: 1px solid #f0f0f0;
}
.ab-stat {
    padding: 44px 28px; border-right: 1px solid #f0f0f0;
    text-align: center; position: relative; transition: background .2s;
}
.ab-stat:hover { background: #fffbeb; }
.ab-stat::after {
    content: ''; position: absolute; bottom: 0; left: 50%;
    transform: translateX(-50%); width: 0; height: 3px;
    background: linear-gradient(90deg, #f59e0b, #e07b00);
    transition: width .3s;
}
.ab-stat:hover::after { width: 60%; }
.ab-stat-num {
    font-size: clamp(2.4rem, 3.5vw, 3.4rem); font-weight: 900; line-height: 1;
    background: linear-gradient(135deg, #0a1628, #1e3a5f);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    display: block; margin-bottom: 6px;
}
.ab-stat-label { font-size: .78rem; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 1px; }
@@media(max-width:768px) { .ab-stats-inner { grid-template-columns: repeat(2,1fr); } }

/* ══ KENTSEL DÖNÜŞÜM ════════════════════════════════════════ */
.ab-urban { padding: 96px 0; background: #f8f9fb; }
.ab-section-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: .72rem; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: #f59e0b; margin-bottom: 12px;
}
.ab-section-label::before { content:''; width:24px; height:2px; background:#f59e0b; display:block; }
.ab-section-title {
    font-size: clamp(1.7rem, 3vw, 2.4rem); font-weight: 900;
    color: #0a1628; line-height: 1.2; margin-bottom: 16px;
}
.ab-section-sub { font-size: .95rem; color: #6b7280; line-height: 1.7; }

.urban-card {
    background: #fff; border-radius: 16px; padding: 32px 28px; height: 100%;
    box-shadow: 0 1px 12px rgba(0,0,0,.05); border: 1px solid #f0f0f0;
    transition: transform .25s, box-shadow .25s;
    position: relative; overflow: hidden;
}
.urban-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, #f59e0b, #e07b00);
    transform: scaleX(0); transform-origin: left; transition: transform .3s;
}
.urban-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.1); }
.urban-card:hover::before { transform: scaleX(1); }
.urban-icon {
    width: 52px; height: 52px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; margin-bottom: 18px;
}
.urban-card h4 { font-size: 1rem; font-weight: 700; color: #0a1628; margin-bottom: 8px; }
.urban-card p  { font-size: .87rem; color: #6b7280; line-height: 1.65; margin: 0; }

/* ══ STORY + TİMELİNE ═══════════════════════════════════════ */
.ab-story { padding: 96px 0; background: #fff; }
.story-img-outer { position: relative; border-radius: 20px; overflow: hidden; }
.story-img-placeholder {
    width: 100%; aspect-ratio: 4/3;
    background: linear-gradient(135deg, #0a1628 0%, #1e3a5f 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 12px; color: rgba(255,255,255,.2); font-size: 5rem;
}
.story-badge {
    position: absolute; bottom: -1px; right: -1px;
    background: linear-gradient(135deg, #f59e0b, #e07b00);
    color: #fff; font-weight: 900;
    padding: 20px 28px; border-radius: 20px 0 20px 0;
    font-size: .85rem; line-height: 1.2;
    box-shadow: 0 8px 24px rgba(245,158,11,.35);
}
.story-badge span { display: block; font-size: 2rem; font-weight: 900; }

.timeline { margin-top: 32px; }
.tl-item { display: flex; gap: 16px; padding-bottom: 24px; }
.tl-item:last-child { padding-bottom: 0; }
.tl-dot-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; padding-top: 4px; }
.tl-dot {
    width: 12px; height: 12px; border-radius: 50%; background: #f59e0b;
    border: 2px solid #fff; box-shadow: 0 0 0 3px rgba(245,158,11,.2); flex-shrink: 0;
}
.tl-line { width: 2px; flex: 1; background: #e5e7eb; margin-top: 6px; }
.tl-item:last-child .tl-line { display: none; }
.tl-year { font-size: .72rem; font-weight: 800; color: #f59e0b; letter-spacing: 1px; margin-bottom: 2px; }
.tl-title { font-size: .9rem; font-weight: 700; color: #0a1628; margin-bottom: 2px; }
.tl-desc  { font-size: .82rem; color: #6b7280; line-height: 1.5; margin: 0; }

/* ══ MVV ════════════════════════════════════════════════════ */
.ab-mvv { padding: 96px 0; background: #f8f9fb; }
.mvv-card {
    background: #fff; border-radius: 20px; padding: 40px 32px; height: 100%;
    box-shadow: 0 2px 16px rgba(0,0,0,.05); border-bottom: 4px solid transparent;
    transition: transform .2s, box-shadow .2s;
}
.mvv-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,.1); }
.mvv-card.mission { border-bottom-color: #f59e0b; }
.mvv-card.vision  { border-bottom-color: #3b82f6; }
.mvv-card.values  { border-bottom-color: #10b981; }
.mvv-icon {
    width: 60px; height: 60px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.9rem; margin-bottom: 22px;
}
.mvv-card.mission .mvv-icon { background: #fef3c7; color: #d97706; }
.mvv-card.vision  .mvv-icon { background: #dbeafe; color: #2563eb; }
.mvv-card.values  .mvv-icon { background: #d1fae5; color: #059669; }
.mvv-card h3 { font-size: 1.2rem; font-weight: 800; color: #0a1628; margin-bottom: 14px; }
.mvv-card p  { font-size: .9rem; color: #6b7280; line-height: 1.75; margin: 0; }
.values-list { list-style: none; padding: 0; margin: 0; }
.values-list li {
    display: flex; align-items: flex-start; gap: 10px;
    margin-bottom: 10px; font-size: .88rem; color: #6b7280; line-height: 1.5;
}
.values-list li::before {
    content: ''; width: 6px; height: 6px; border-radius: 50%;
    background: #10b981; flex-shrink: 0; margin-top: 6px;
}

/* ══ REFERENCES BAND ════════════════════════════════════════ */
.ab-refs { padding: 80px 0; background: #fff; border-top: 1px solid #f0f0f0; }
.refs-logo-grid {
    display: flex; flex-wrap: wrap; gap: 16px;
    justify-content: center; align-items: center; margin-top: 48px;
}
.ref-logo-item {
    background: #f8f9fb; border: 1px solid #e5e7eb; border-radius: 12px;
    padding: 20px 32px; font-size: .88rem; font-weight: 700;
    color: #374151; transition: all .2s; text-align: center; min-width: 160px;
}
.ref-logo-item:hover {
    border-color: #f59e0b; background: #fffbeb; color: #92400e;
    transform: translateY(-2px); box-shadow: 0 4px 16px rgba(245,158,11,.15);
}

/* ══ CTA ════════════════════════════════════════════════════ */
.ab-cta {
    padding: 96px 0;
    background: linear-gradient(135deg, #0a1628 0%, #1e3a5f 100%);
    text-align: center; color: #fff; position: relative; overflow: hidden;
}
.ab-cta::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 700px 500px at 50% 50%, rgba(245,158,11,.08) 0%, transparent 70%);
    pointer-events: none;
}
.ab-cta h2 { font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 900; margin-bottom: 14px; }
.ab-cta p  { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 32px; max-width: 480px; margin-left: auto; margin-right: auto; }

/* ══ REVEAL ═════════════════════════════════════════════════ */
.reveal { opacity: 0; transform: translateY(28px); transition: opacity .6s ease, transform .6s ease; }
.reveal.visible { opacity: 1; transform: none; }
.delay-1 { transition-delay: .1s; }
.delay-2 { transition-delay: .2s; }
.delay-3 { transition-delay: .3s; }
</style>
}

<!-- ══ HERO (Video Arka Plan) ══════════════════════════════ -->
<section class="ab-hero">
    <video class="ab-hero-video" autoplay muted loop playsinline>
        <source src="/videos/hakkimizda-hero.mp4" type="video/mp4" />
    </video>
    <div class="ab-hero-overlay"></div>
    <div class="container ab-hero-content">
        <div class="row align-items-center g-5">
            <div class="col-lg-8">
                <div class="ab-eyebrow">@(isEn ? "Who We Are" : "Biz Kimiz")</div>
                <h1>
                    @if (isEn) {
                        @Html.Raw("Shaping Cities,<br/><span>Building the Future</span>")
                    } else {
                        @Html.Raw("Şehirleri Dönüştürüyor,<br/><span>Geleceği İnşa Ediyoruz</span>")
                    }
                </h1>
                <p>@(isEn
                    ? "Brikon Yapı has been at the forefront of urban transformation in Turkey for over 25 years — delivering landmark projects in partnership with TOKİ, universities, hospitals, and major institutions across the country."
                    : "Brikon Yapı; 25 yılı aşkın süredir Türkiye'nin kentsel dönüşümünde öncü bir rol üstlenerek TOKİ, üniversiteler, hastaneler ve köklü kurumlarla iş birliği içinde hayata geçirdiği imza projelerle fark yaratmaktadır.")</p>
                <div class="ab-hero-badges">
                    <span class="ab-badge"><iconify-icon icon="iconamoon:building-duotone"></iconify-icon> @(isEn ? "37 Projects" : "37 Proje")</span>
                    <span class="ab-badge"><iconify-icon icon="iconamoon:location-pin-duotone"></iconify-icon> @(isEn ? "10+ Cities" : "10+ Şehir")</span>
                    <span class="ab-badge"><iconify-icon icon="iconamoon:calendar-duotone"></iconify-icon> @(isEn ? "25+ Years" : "25+ Yıllık Deneyim")</span>
                    <span class="ab-badge"><iconify-icon icon="iconamoon:star-duotone"></iconify-icon> @(isEn ? "TOKİ Partner" : "TOKİ İş Ortağı")</span>
                </div>
            </div>
        </div>
    </div>
    <div class="ab-scroll">
        <div class="ab-scroll-line"></div>
    </div>
</section>

<!-- ══ STATS ═══════════════════════════════════════════════ -->
<section class="ab-stats">
    <div class="container">
        <div class="ab-stats-inner">
            <div class="ab-stat reveal">
                <span class="ab-stat-num">37+</span>
                <div class="ab-stat-label">@(isEn ? "Completed Projects" : "Tamamlanan Proje")</div>
            </div>
            <div class="ab-stat reveal delay-1">
                <span class="ab-stat-num">25+</span>
                <div class="ab-stat-label">@(isEn ? "Years of Experience" : "Yıllık Deneyim")</div>
            </div>
            <div class="ab-stat reveal delay-2">
                <span class="ab-stat-num">10+</span>
                <div class="ab-stat-label">@(isEn ? "Cities" : "Farklı Şehir")</div>
            </div>
            <div class="ab-stat reveal delay-3">
                <span class="ab-stat-num">6+</span>
                <div class="ab-stat-label">@(isEn ? "Institutional Partners" : "Kurumsal İş Ortağı")</div>
            </div>
        </div>
    </div>
</section>

<!-- ══ KENTSEL DÖNÜŞÜM HİZMETLERİ ════════════════════════ -->
<section class="ab-urban">
    <div class="container">
        <div class="row g-5 align-items-center mb-5">
            <div class="col-lg-6 reveal">
                <div class="ab-section-label">@(isEn ? "Urban Transformation" : "Kentsel Dönüşüm")</div>
                <h2 class="ab-section-title">
                    @if (isEn) { @Html.Raw("Rebuilding Cities,<br/>One Project at a Time") }
                    else       { @Html.Raw("Şehirleri Yeniden<br/>İnşa Ediyoruz") }
                </h2>
                <p class="ab-section-sub">@(isEn
                    ? "From mass housing to university campuses and state hospitals, Brikon Yapı has been transforming Turkey's urban landscape through safe, modern, and sustainable construction."
                    : "Toplu konuttan üniversite kampüslerine, devlet hastanelerinden köy dönüşüm projelerine kadar Brikon Yapı; güvenli, modern ve sürdürülebilir yapılarla Türkiye'nin kentsel dokusunu yeniden şekillendiriyor.")</p>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3 reveal">
                <div class="urban-card">
                    <div class="urban-icon" style="background:#fef3c7;">
                        <iconify-icon icon="iconamoon:home-duotone" style="color:#d97706;"></iconify-icon>
                    </div>
                    <h4>@(isEn ? "Mass Housing (TOKİ)" : "Toplu Konut (TOKİ)")</h4>
                    <p>@(isEn ? "State-sponsored affordable housing projects across multiple cities in partnership with TOKİ." : "TOKİ iş birliğiyle birden fazla şehirde hayata geçirilen devlet destekli uygun fiyatlı konut projeleri.")</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 reveal delay-1">
                <div class="urban-card">
                    <div class="urban-icon" style="background:#dbeafe;">
                        <iconify-icon icon="iconamoon:building-apartment-duotone" style="color:#2563eb;"></iconify-icon>
                    </div>
                    <h4>@(isEn ? "Campus & Education" : "Kampüs ve Eğitim")</h4>
                    <p>@(isEn ? "University faculties, congress centers, dormitories and vocational schools across Turkey." : "Türkiye genelinde üniversite fakülteleri, kongre merkezleri, yurtlar ve meslek yüksekokulları.")</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 reveal delay-2">
                <div class="urban-card">
                    <div class="urban-icon" style="background:#d1fae5;">
                        <iconify-icon icon="iconamoon:heart-duotone" style="color:#059669;"></iconify-icon>
                    </div>
                    <h4>@(isEn ? "Healthcare Facilities" : "Sağlık Yapıları")</h4>
                    <p>@(isEn ? "State hospitals and healthcare infrastructure built to the highest safety standards." : "En yüksek güvenlik standartlarında inşa edilen devlet hastaneleri ve sağlık altyapısı.")</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3 reveal delay-3">
                <div class="urban-card">
                    <div class="urban-icon" style="background:#ede9fe;">
                        <iconify-icon icon="iconamoon:star-duotone" style="color:#7c3aed;"></iconify-icon>
                    </div>
                    <h4>@(isEn ? "Luxury Residences" : "Lüks Konut")</h4>
                    <p>@(isEn ? "Premium apartment and villa projects in Istanbul, Ankara, Bodrum and beyond." : "İstanbul, Ankara, Bodrum ve daha birçok şehirde premium daire ve villa projeleri.")</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ HİKAYE + TİMELİNE ══════════════════════════════════ -->
<section class="ab-story">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-5 reveal">
                <div class="story-img-outer">
                    <div class="story-img-placeholder">
                        <iconify-icon icon="iconamoon:building-apartment-duotone"></iconify-icon>
                        <span style="font-size:1rem;letter-spacing:2px;text-transform:uppercase;">Brikon Yapı</span>
                    </div>
                    <div class="story-badge">
                        <span>25+</span>
                        @(isEn ? "Years of<br/>Experience" : "Yıllık<br/>Deneyim")
                    </div>
                </div>
            </div>
            <div class="col-lg-7 reveal delay-1">
                <div class="ab-section-label">@(isEn ? "Our Story" : "Hikayemiz")</div>
                <h2 class="ab-section-title">
                    @if (isEn) { @Html.Raw("Decades of Urban<br/>Transformation") }
                    else       { @Html.Raw("On Yıllardır Kentsel<br/>Dönüşümün Öncüsü") }
                </h2>
                <p style="font-size:.93rem;color:#6b7280;line-height:1.75;margin-bottom:32px;">@(isEn
                    ? "From TOKİ-backed village villas in Afyonkarahisar to Hacettepe University's grand congress center, from Istanbul Airport facilities to Safranbolu's UNESCO-listed historic mansion restoration — every project tells a story of transformation."
                    : "Afyonkarahisar'daki TOKİ tarımköy villalarından Hacettepe Üniversitesi'nin büyük kongre merkezine, İstanbul Havalimanı tesislerinden Safranbolu'nun UNESCO listesindeki tarihi konak restorasyonuna kadar her proje bir dönüşüm hikayesi anlatıyor.")</p>
                <div class="timeline">
                    <div class="tl-item">
                        <div class="tl-dot-wrap"><div class="tl-dot"></div><div class="tl-line"></div></div>
                        <div>
                            <div class="tl-year">1998 – 2005</div>
                            <div class="tl-title">@(isEn ? "Foundation & First Projects" : "Kuruluş ve İlk Projeler")</div>
                            <p class="tl-desc">@(isEn ? "Zonguldak Alaplı MYO, Safranbolu Fine Arts High School and early Hacettepe University projects." : "Zonguldak Alaplı MYO, Safranbolu Güzel Sanatlar Lisesi ve ilk Hacettepe Üniversitesi projeleri.")</p>
                        </div>
                    </div>
                    <div class="tl-item">
                        <div class="tl-dot-wrap"><div class="tl-dot"></div><div class="tl-line"></div></div>
                        <div>
                            <div class="tl-year">2005 – 2010</div>
                            <div class="tl-title">@(isEn ? "Campus Expansion" : "Kampüs Genişlemesi")</div>
                            <p class="tl-desc">@(isEn ? "Hacettepe University Congress Center (22,000 m²), Mechanical Engineering Faculty and more." : "Hacettepe Üniversitesi Kongre Merkezi (22.000 m²), Makina Mühendisliği Fakültesi ve daha fazlası.")</p>
                        </div>
                    </div>
                    <div class="tl-item">
                        <div class="tl-dot-wrap"><div class="tl-dot"></div><div class="tl-line"></div></div>
                        <div>
                            <div class="tl-year">2011 – 2015</div>
                            <div class="tl-title">@(isEn ? "TOKİ & Public Health" : "TOKİ & Kamu Sağlığı")</div>
                            <p class="tl-desc">@(isEn ? "110 TOKİ villas in Afyonkarahisar and Devrek State Hospital (22,500 m²) with 600 piled foundations." : "Afyonkarahisar'da 110 TOKİ villası ve 600 kazıklı temelli Devrek Devlet Hastanesi (22.500 m²).")</p>
                        </div>
                    </div>
                    <div class="tl-item">
                        <div class="tl-dot-wrap"><div class="tl-dot"></div></div>
                        <div>
                            <div class="tl-year">@(isEn ? "Today" : "Günümüz")</div>
                            <div class="tl-title">@(isEn ? "Airport & Luxury" : "Havalimanı & Lüks Konut")</div>
                            <p class="tl-desc">@(isEn ? "IGA Istanbul Airport, Trakpark Premium 42-villa complex in Tekirdağ and ongoing luxury projects." : "İGA İstanbul Havalimanı, Tekirdağ'da 42 villalı Trakpark Premium ve devam eden lüks projeler.")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

