@{
    bool isEn = ViewBag.IsEn == true;
    ViewData["Title"]       = isEn ? "About Us" : "Hakkımızda";
    ViewData["Description"] = isEn
        ? "Brikon Yapı – Building the future with quality and trust since our foundation."
        : "Brikon Yapı – Kuruluşumuzdan bu yana kalite ve güvenle geleceği inşa ediyoruz.";
}

@section Styles {
<style>
/* ── Hero ── */
.about-hero {
    background: linear-gradient(135deg, #0c1420 0%, #1a2c42 60%, #0e1f33 100%);
    padding: 100px 0 72px;
    color: #fff;
    position: relative;
    overflow: hidden;
}
.about-hero::after {
    content: '';
    position: absolute; right: -80px; top: -80px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(245,158,11,.12) 0%, transparent 70%);
    pointer-events: none;
}
.about-hero .sh-eyebrow {
    font-size: .72rem; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: #f59e0b;
    display: block; margin-bottom: 12px;
}
.about-hero h1 {
    font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800;
    margin-bottom: 18px; line-height: 1.15;
}
.about-hero p {
    font-size: 1.05rem; color: rgba(255,255,255,.65);
    max-width: 560px; line-height: 1.7;
}
.about-hero-line {
    width: 52px; height: 4px;
    background: linear-gradient(90deg, #f59e0b, #e07b00);
    border-radius: 2px; margin: 24px 0;
}

/* ── Mission/Vision ── */
.mv-section { padding: 80px 0; background: #f8f9fb; }
.mv-card {
    background: #fff; border-radius: 16px;
    padding: 36px 32px;
    box-shadow: 0 2px 20px rgba(0,0,0,.06);
    height: 100%;
    border-top: 4px solid transparent;
    transition: transform .2s, box-shadow .2s;
}
.mv-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(0,0,0,.1); }
.mv-card.mission { border-top-color: #f59e0b; }
.mv-card.vision  { border-top-color: #3b82f6; }
.mv-card.values  { border-top-color: #10b981; }
.mv-icon {
    width: 56px; height: 56px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem; margin-bottom: 20px;
}
.mv-card.mission .mv-icon { background: #fef3c7; color: #d97706; }
.mv-card.vision  .mv-icon { background: #dbeafe; color: #2563eb; }
.mv-card.values  .mv-icon { background: #d1fae5; color: #059669; }
.mv-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 12px; color: #1a2332; }
.mv-card p  { font-size: .9rem; color: #5a6a7a; line-height: 1.7; margin: 0; }

/* ── Stats ── */
.about-stats { padding: 72px 0; background: #fff; }
.astat-item { text-align: center; padding: 24px 16px; }
.astat-num {
    font-size: clamp(2.4rem, 4vw, 3.6rem); font-weight: 900;
    color: #1a2332; line-height: 1;
    background: linear-gradient(135deg, #1a2332, #f59e0b);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.astat-label { font-size: .82rem; font-weight: 600; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-top: 6px; }
.astat-sep { width: 1px; background: #e5e7eb; align-self: stretch; margin: 8px 0; }

/* ── Değerlerimiz listesi ── */
.values-list { list-style: none; padding: 0; margin: 0; }
.values-list li {
    display: flex; align-items: flex-start; gap: 10px;
    margin-bottom: 10px; font-size: .9rem; color: #5a6a7a; line-height: 1.5;
}
.values-list li::before {
    content: '✦';
    color: #10b981; font-size: .7rem; margin-top: 3px; flex-shrink: 0;
}

/* ── Story ── */
.about-story { padding: 80px 0; background: #f8f9fb; }
.story-img-wrap {
    border-radius: 16px; overflow: hidden;
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, #1a2c42, #0e1f33);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,.15); font-size: 5rem;
}
.story-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: .72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: #f59e0b; margin-bottom: 14px;
}
.story-tag::before { content:''; display:inline-block; width:28px; height:2px; background:#f59e0b; }
.story-title { font-size: clamp(1.4rem, 2.5vw, 2rem); font-weight: 800; color: #1a2332; margin-bottom: 16px; line-height: 1.2; }
.story-text  { font-size: .92rem; color: #5a6a7a; line-height: 1.8; }

/* ── CTA ── */
.about-cta {
    padding: 72px 0;
    background: linear-gradient(135deg, #1a2332 0%, #1e3a5f 100%);
    text-align: center; color: #fff;
}
.about-cta h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 800; margin-bottom: 12px; }
.about-cta p  { color: rgba(255,255,255,.6); font-size: .95rem; margin-bottom: 28px; }
</style>
}

<!-- ── Hero ── -->
<section class="about-hero">
    <div class="container">
        <span class="sh-eyebrow">@(isEn ? "Who We Are" : "Biz Kimiz")</span>
        <h1>@(isEn ? "Building the Future<br/>with Confidence" : "Güvenle<br/>Geleceği İnşa Ediyoruz")</h1>
        <div class="about-hero-line"></div>
        <p>@(isEn
            ? "Since our founding, Brikon Yapı has been delivering high-quality residential and commercial construction projects with a commitment to trust, innovation, and excellence."
            : "Kuruluşumuzdan bu yana Brikon Yapı; güven, yenilik ve mükemmeliyete olan bağlılığımızla yüksek kaliteli konut ve ticari inşaat projeleri hayata geçirmeye devam etmektedir.")</p>
    </div>
</section>

<!-- ── Mission / Vision / Values ── -->
<section class="mv-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="mv-card mission reveal">
                    <div class="mv-icon">
                        <iconify-icon icon="iconamoon:target-duotone"></iconify-icon>
                    </div>
                    <h3>@(isEn ? "Our Mission" : "Misyonumuz")</h3>
                    <p>@(isEn
                        ? "To develop sustainable, high-quality living spaces that go beyond merely constructing buildings — we create communities where people truly want to live."
                        : "Yalnızca bina inşa etmenin ötesine geçerek insanların gerçekten yaşamak istediği, sürdürülebilir ve kaliteli yaşam alanları geliştirmek.")</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mv-card vision reveal delay-1">
                    <div class="mv-icon">
                        <iconify-icon icon="iconamoon:eye-duotone"></iconify-icon>
                    </div>
                    <h3>@(isEn ? "Our Vision" : "Vizyonumuz")</h3>
                    <p>@(isEn
                        ? "To become Turkey's most trusted construction company by delivering innovative projects that enhance the quality of life for thousands of families."
                        : "Binlerce ailenin yaşam kalitesini artıran yenilikçi projelerle Türkiye'nin en güvenilir inşaat şirketi olmak.")</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mv-card values reveal delay-2">
                    <div class="mv-icon">
                        <iconify-icon icon="iconamoon:star-duotone"></iconify-icon>
                    </div>
                    <h3>@(isEn ? "Our Values" : "Değerlerimiz")</h3>
                    <ul class="values-list">
                        <li>@(isEn ? "Quality & Craftsmanship" : "Kalite ve İşçilik")</li>
                        <li>@(isEn ? "Trust & Transparency" : "Güven ve Şeffaflık")</li>
                        <li>@(isEn ? "Innovation & Sustainability" : "Yenilik ve Sürdürülebilirlik")</li>
                        <li>@(isEn ? "Customer Satisfaction" : "Müşteri Memnuniyeti")</li>
                        <li>@(isEn ? "Timely Delivery" : "Zamanında Teslimat")</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── İstatistikler ── -->
<section class="about-stats">
    <div class="container">
        <div class="row g-0 text-center">
            <div class="col-6 col-md-3">
                <div class="astat-item">
                    <div class="astat-num">45+</div>
                    <div class="astat-label">@(isEn ? "Projects" : "Proje")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="astat-item" style="border-left:1px solid #e5e7eb;">
                    <div class="astat-num">15+</div>
                    <div class="astat-label">@(isEn ? "Years of Experience" : "Yıllık Deneyim")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="astat-item" style="border-left:1px solid #e5e7eb;border-top:1px solid #e5e7eb;">
                    <div class="astat-num">5K+</div>
                    <div class="astat-label">@(isEn ? "Happy Families" : "Mutlu Aile")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="astat-item" style="border-left:1px solid #e5e7eb;border-top:1px solid #e5e7eb;">
                    <div class="astat-num">10+</div>
                    <div class="astat-label">@(isEn ? "Cities" : "Şehir")</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Hikayemiz ── -->
<section class="about-story">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6 reveal">
                <div class="story-img-wrap">
                    <iconify-icon icon="iconamoon:building-apartment-duotone"></iconify-icon>
                </div>
            </div>
            <div class="col-lg-6 reveal delay-1">
                <span class="story-tag">@(isEn ? "Our Story" : "Hikayemiz")</span>
                <h2 class="story-title">@(isEn ? "Decades of Building Dreams" : "On Yıllardır Hayalleri İnşa Ediyoruz")</h2>
                <p class="story-text">@(isEn
                    ? "Brikon Yapı was founded with a simple but powerful vision: to build homes that families are proud to live in. Over the years, we have grown from a small regional contractor to one of the most respected names in Turkish construction, completing projects in over 10 cities across the country."
                    : "Brikon Yapı; ailelerin gururla yaşadığı evler inşa etmek gibi sade ama güçlü bir vizyonla kuruldu. Yıllar içinde küçük bir bölgesel müteahhitten Türkiye'nin en saygın inşaat firmalarından biri haline geldik ve ülke genelinde 10'dan fazla şehirde projeler tamamladık.")</p>
                <p class="story-text mt-3">@(isEn
                    ? "From mass housing projects developed in partnership with TOKİ to luxury residential complexes, every project we undertake reflects our unwavering commitment to quality, safety, and customer satisfaction."
                    : "TOKİ iş birliğiyle hayata geçirilen toplu konut projelerinden lüks konut komplekslerine kadar üstlendiğimiz her proje; kalite, güvenlik ve müşteri memnuniyetine olan sarsılmaz bağlılığımızın bir yansımasıdır.")</p>
            </div>
        </div>
    </div>
</section>

<!-- ── CTA ── -->
<section class="about-cta">
    <div class="container">
        <h2>@(isEn ? "Ready to Start Your Project?" : "Projenize Başlamaya Hazır Mısınız?")</h2>
        <p>@(isEn ? "Contact us today and let's build something great together." : "Bugün bize ulaşın, birlikte harika şeyler inşa edelim.")</p>
        <a href="/Projeler" class="btn btn-warning btn-lg fw-bold px-5" style="border-radius:10px;">
            @(isEn ? "View Our Projects" : "Projelerimizi İncele")
        </a>
    </div>
</section>
