<!-- ══ CTA ════════════════════════════════════════════════ -->
<section class="ab-cta">
    <div class="container" style="position:relative;z-index:1;">
        <h2 class="reveal">@(isEn ? "Ready to Start Your Project?" : "Projenize Başlamaya Hazır Mısınız?")</h2>
        <p class="reveal delay-1">@(isEn
            ? "Contact us today and let's build something great together."
            : "Bugün bize ulaşın, birlikte harika şeyler inşa edelim.")</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap reveal delay-2">
            <a href="/Iletisim" class="btn btn-warning btn-lg fw-bold px-5" style="border-radius:10px;">
                @(isEn ? "Contact Us" : "İletişime Geç")
            </a>
            <a href="/Projeler" class="btn btn-outline-light btn-lg px-5" style="border-radius:10px;">
                @(isEn ? "View Projects" : "Projelerimiz")
            </a>
        </div>
    </div>
</section>

@section Scripts {
<script>
(function(){
    var els = document.querySelectorAll('.reveal');
    var io  = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach(function(el){ io.observe(el); });
})();
</script>
}
