@{
    bool isEn = ViewBag.IsEn == true;
    ViewData["Title"]       = isEn ? "About Us" : "Hakkımızda";
    ViewData["Description"] = isEn
        ? "Brikon Yapı – Urban transformation and construction excellence since 1998."
        : "Brikon Yapı – 1998'den bu yana kentsel dönüşüm ve inşaat alanında köklü deneyim.";
}

@section Styles {
<style>
/* ── RESET / TOKENS ─────────────────────────────────────── */
:root {
    --ink:    #0d1117;
    --ink2:   #4b5563;
    --gold:   #c8960c;
    --gold-l: #fef3c7;
    --line:   #e5e7eb;
    --bg:     #f9fafb;
}

/* ── HERO ────────────────────────────────────────────────── */
.hk-hero {
    position: relative;
    height: 100svh; min-height: 560px;
    display: flex; align-items: flex-end;
    overflow: hidden; color: #fff;
}
.hk-hero-video {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    z-index: 0;
}
.hk-hero-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(to top,
        rgba(5,10,20,.88) 0%,
        rgba(5,10,20,.50) 55%,
        rgba(5,10,20,.20) 100%);
}
.hk-hero-body {
    position: relative; z-index: 2;
    padding-bottom: 80px; width: 100%;
}
.hk-tag {
    display: inline-block;
    font-size: .68rem; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--gold);
    border-left: 2px solid var(--gold); padding-left: 10px;
    margin-bottom: 20px;
}
.hk-hero h1 {
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    font-weight: 800; line-height: 1.1;
    max-width: 720px; margin-bottom: 20px;
}
.hk-hero p {
    font-size: 1rem; color: rgba(255,255,255,.65);
    max-width: 540px; line-height: 1.8;
}
.hk-hero-scroll {
    position: absolute; right: 40px; bottom: 40px; z-index: 2;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    color: rgba(255,255,255,.3); font-size: .6rem; letter-spacing: 2.5px;
    text-transform: uppercase;
}
.hk-hero-scroll-line {
    width: 1px; height: 48px;
    background: linear-gradient(to bottom, rgba(255,255,255,.25), transparent);
    animation: scrollLine 1.8s ease-in-out infinite;
}
@@keyframes scrollLine {
    0%,100% { opacity: .4; transform: scaleY(1); transform-origin: top; }
    50%      { opacity: 1;  transform: scaleY(1.15); }
}

/* ── STATS ───────────────────────────────────────────────── */
.hk-stats {
    background: var(--ink); color: #fff;
    border-bottom: 1px solid rgba(255,255,255,.06);
}
.hk-stats-grid {
    display: grid; grid-template-columns: repeat(4,1fr);
    border-left: 1px solid rgba(255,255,255,.08);
}
.hk-stat {
    padding: 40px 24px; text-align: center;
    border-right: 1px solid rgba(255,255,255,.08);
}
.hk-stat-n {
    font-size: clamp(2.2rem, 3vw, 3rem);
    font-weight: 800; color: var(--gold); display: block;
    line-height: 1; margin-bottom: 8px;
}
.hk-stat-l {
    font-size: .72rem; font-weight: 600;
    color: rgba(255,255,255,.4);
    text-transform: uppercase; letter-spacing: 1px;
}
@@media(max-width:640px) { .hk-stats-grid { grid-template-columns: repeat(2,1fr); } }

/* ── SECTION COMMON ──────────────────────────────────────── */
.hk-sec { padding: 100px 0; }
.hk-sec-alt { background: var(--bg); }
.hk-label {
    font-size: .68rem; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 14px; display: block;
}
.hk-h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800; color: var(--ink); line-height: 1.2;
    margin-bottom: 18px;
}
.hk-lead { font-size: .95rem; color: var(--ink2); line-height: 1.8; }

/* ── SERVICE GRID ────────────────────────────────────────── */
.hk-svc-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
.hk-svc-item {
    background: #fff; padding: 36px 32px;
    transition: background .2s;
}
.hk-svc-item:hover { background: #fffdf5; }
.hk-svc-num {
    font-size: .68rem; font-weight: 800;
    letter-spacing: 2px; color: var(--gold); margin-bottom: 14px; display: block;
}
.hk-svc-item h4 { font-size: 1rem; font-weight: 700; color: var(--ink); margin-bottom: 8px; }
.hk-svc-item p  { font-size: .87rem; color: var(--ink2); line-height: 1.65; margin: 0; }
@@media(max-width:560px) { .hk-svc-grid { grid-template-columns: 1fr; } }

/* ── TIMELINE ────────────────────────────────────────────── */
.hk-tl { margin-top: 48px; }
.hk-tl-item { display: flex; gap: 20px; padding-bottom: 32px; position: relative; }
.hk-tl-left { flex-shrink: 0; width: 64px; text-align: right; padding-top: 2px; }
.hk-tl-yr { font-size: .72rem; font-weight: 800; color: var(--gold); letter-spacing: .5px; }
.hk-tl-spine {
    flex-shrink: 0; display: flex; flex-direction: column; align-items: center;
}
.hk-tl-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--gold); margin-top: 4px; flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(200,150,12,.15);
}
.hk-tl-bar { width: 1px; background: var(--line); flex: 1; margin-top: 6px; }
.hk-tl-item:last-child .hk-tl-bar { display: none; }
.hk-tl-body h5 { font-size: .9rem; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
.hk-tl-body p  { font-size: .83rem; color: var(--ink2); line-height: 1.55; margin: 0; }

/* ── MVV ─────────────────────────────────────────────────── */
.hk-mvv-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
.hk-mvv-item {
    background: #fff; padding: 44px 36px;
}
.hk-mvv-item h3 {
    font-size: 1.05rem; font-weight: 800; color: var(--ink);
    margin-bottom: 14px; padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
}
.hk-mvv-item p  { font-size: .88rem; color: var(--ink2); line-height: 1.75; margin: 0; }
.hk-values-list { list-style: none; padding: 0; margin: 0; }
.hk-values-list li {
    font-size: .88rem; color: var(--ink2); line-height: 1.6;
    padding: 5px 0; border-bottom: 1px solid var(--line);
    display: flex; align-items: center; gap: 10px;
}
.hk-values-list li:last-child { border: none; }
.hk-values-list li::before {
    content: ''; width: 5px; height: 5px; border-radius: 50%;
    background: var(--gold); flex-shrink: 0;
}
@@media(max-width:768px) { .hk-mvv-grid { grid-template-columns: 1fr; } }

/* ── REFERENCES MARQUEE ──────────────────────────────────── */
.hk-refs-outer {
    overflow: hidden; margin-top: 48px;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
}
.hk-refs-track {
    display: flex; gap: 0; width: max-content;
    animation: hkRefsScroll 28s linear infinite;
    will-change: transform;
}
.hk-refs-track:hover { animation-play-state: paused; }
@@keyframes hkRefsScroll {
    from { transform: translate3d(0,0,0); }
    to   { transform: translate3d(-50%,0,0); }
}
.hk-ref-chip {
    display: flex; align-items: center; justify-content: center;
    padding: 20px 40px;
    border-right: 1px solid var(--line);
    min-width: 200px; transition: background .2s;
    cursor: default;
}
.hk-ref-chip:hover { background: var(--gold-l); }
.hk-ref-chip img {
    height: 48px; width: auto; max-width: 140px;
    object-fit: contain; opacity: .7; transition: opacity .25s;
}
.hk-ref-chip:hover img { opacity: 1; }
.hk-ref-chip-name {
    font-size: .82rem; font-weight: 700; color: var(--ink2);
    white-space: nowrap; letter-spacing: .03em;
    transition: color .2s;
}
.hk-ref-chip:hover .hk-ref-chip-name { color: var(--ink); }

/* ── CTA BAND ────────────────────────────────────────────── */
.hk-cta {
    background: var(--ink); color: #fff;
    padding: 96px 0; text-align: center;
}
.hk-cta h2 {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 800; margin-bottom: 12px;
}
.hk-cta p {
    font-size: .95rem; color: rgba(255,255,255,.45);
    margin-bottom: 36px;
}
.hk-cta-btn {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--gold); color: var(--ink);
    font-size: .88rem; font-weight: 700; letter-spacing: .4px;
    border: none; padding: 14px 40px; border-radius: 3px;
    cursor: pointer; transition: opacity .2s;
}
.hk-cta-btn:hover { opacity: .85; }

/* ── CONTACT MODAL ───────────────────────────────────────── */
.hk-modal-backdrop {
    position: fixed; inset: 0; z-index: 1050;
    background: rgba(5,10,20,.72);
    backdrop-filter: blur(4px);
    display: flex; align-items: center; justify-content: center;
    padding: 20px;
    opacity: 0; pointer-events: none;
    transition: opacity .25s;
}
.hk-modal-backdrop.open { opacity: 1; pointer-events: all; }
.hk-modal-box {
    background: #111827; color: #fff;
    border-radius: 6px; width: 100%; max-width: 560px;
    max-height: 90svh; overflow-y: auto;
    transform: translateY(20px); transition: transform .25s;
    position: relative;
}
.hk-modal-backdrop.open .hk-modal-box { transform: translateY(0); }
.hk-modal-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 28px 20px; border-bottom: 1px solid rgba(255,255,255,.08);
}
.hk-modal-head h3 { font-size: 1.05rem; font-weight: 700; margin: 0; }
.hk-modal-close {
    background: none; border: none; color: rgba(255,255,255,.4);
    font-size: 1.4rem; line-height: 1; cursor: pointer; padding: 0;
    transition: color .15s;
}
.hk-modal-close:hover { color: #fff; }
.hk-modal-body { padding: 28px; }

/* form inside modal */
.hk-form .form-label {
    font-size: .68rem; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: rgba(255,255,255,.45); margin-bottom: 6px;
}
.hk-form .form-control {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.1);
    color: #fff; border-radius: 3px;
    font-size: .9rem; padding: 11px 14px;
}
.hk-form .form-control::placeholder { color: rgba(255,255,255,.2); }
.hk-form .form-control:focus {
    background: rgba(255,255,255,.09);
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(200,150,12,.12);
    color: #fff;
}
.hk-form textarea.form-control { resize: none; }
.hk-btn-send {
    background: var(--gold); color: var(--ink);
    border: none; padding: 13px 36px;
    font-size: .88rem; font-weight: 700;
    letter-spacing: .4px; border-radius: 3px;
    transition: opacity .2s; cursor: pointer; width: 100%;
}
.hk-btn-send:hover { opacity: .88; }

/* alerts */
.hk-alert-ok {
    background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.3);
    color: #6ee7b7; border-radius: 3px;
    padding: 12px 16px; font-size: .88rem; margin-bottom: 16px;
    display: flex; align-items: center; gap: 8px;
}
.hk-alert-err {
    background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.3);
    color: #fca5a5; border-radius: 3px;
    padding: 12px 16px; font-size: .88rem; margin-bottom: 16px;
}

/* ── REVEAL ──────────────────────────────────────────────── */
.rv { opacity: 0; transform: translateY(24px); transition: opacity .55s ease, transform .55s ease; }
.rv.on { opacity: 1; transform: none; }
.d1 { transition-delay: .1s; }
.d2 { transition-delay: .2s; }
.d3 { transition-delay: .3s; }
</style>
}

<!-- ── HERO ─────────────────────────────────────────────── -->
<section class="hk-hero">
    <video class="hk-hero-video" autoplay muted loop playsinline>
        <source src="/videos/hakkimizda-hero.mp4" type="video/mp4" />
    </video>
    <div class="hk-hero-overlay"></div>
    <div class="container hk-hero-body">
        <span class="hk-tag">@(isEn ? "About Brikon Yapı" : "Brikon Yapı Hakkında")</span>
        <h1>
            @if (isEn) { @Html.Raw("Building Turkey's<br/>Urban Future") }
            else       { @Html.Raw("Türkiye'nin Kentsel<br/>Geleceğini İnşa Ediyoruz") }
        </h1>
        <p>@(isEn
            ? "25 years of landmark projects — from TOKİ housing to university campuses, state hospitals and luxury residences."
            : "25 yıldır TOKİ projelerinden üniversite kampüslerine, devlet hastanelerinden lüks konutlara kadar imza niteliğinde yapılar.")</p>
    </div>
    <div class="hk-hero-scroll">
        <div class="hk-hero-scroll-line"></div>
        <span>scroll</span>
    </div>
</section>

<!-- ── STATS ─────────────────────────────────────────────── -->
<section class="hk-stats">
    <div class="container-fluid px-0">
        <div class="hk-stats-grid">
            <div class="hk-stat rv">
                <span class="hk-stat-n">37+</span>
                <div class="hk-stat-l">@(isEn ? "Completed Projects" : "Tamamlanan Proje")</div>
            </div>
            <div class="hk-stat rv d1">
                <span class="hk-stat-n">25+</span>
                <div class="hk-stat-l">@(isEn ? "Years Experience" : "Yıllık Deneyim")</div>
            </div>
            <div class="hk-stat rv d2">
                <span class="hk-stat-n">10+</span>
                <div class="hk-stat-l">@(isEn ? "Cities" : "Farklı Şehir")</div>
            </div>
            <div class="hk-stat rv d3">
                <span class="hk-stat-n">6+</span>
                <div class="hk-stat-l">@(isEn ? "Institutional Partners" : "Kurumsal İş Ortağı")</div>
            </div>
        </div>
    </div>
</section>

<!-- ── HİZMET ALANLARI ───────────────────────────────────── -->
<section class="hk-sec">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-4 rv">
                <span class="hk-label">@(isEn ? "What We Do" : "Ne Yapıyoruz")</span>
                <h2 class="hk-h2">
                    @if (isEn) { @Html.Raw("Four Decades of<br/>Construction Excellence") }
                    else       { @Html.Raw("Güvenli, Modern<br/>ve Sürdürülebilir Yapılar") }
                </h2>
                <p class="hk-lead">@(isEn
                    ? "Brikon Yapı operates across mass housing, higher education, public health and premium residential sectors."
                    : "Brikon Yapı; toplu konut, yükseköğretim, kamu sağlığı ve premium konut sektörlerinde faaliyet göstermektedir.")</p>
            </div>
            <div class="col-lg-8 rv d1">
                <div class="hk-svc-grid">
                    <div class="hk-svc-item">
                        <span class="hk-svc-num">01</span>
                        <h4>@(isEn ? "Mass Housing (TOKİ)" : "Toplu Konut (TOKİ)")</h4>
                        <p>@(isEn ? "State-sponsored housing projects across multiple cities in partnership with TOKİ, delivered on time and within budget." : "TOKİ iş birliğiyle çok sayıda şehirde zamanında ve bütçe dahilinde teslim edilen devlet destekli konut projeleri.")</p>
                    </div>
                    <div class="hk-svc-item">
                        <span class="hk-svc-num">02</span>
                        <h4>@(isEn ? "Campus & Education" : "Kampüs & Eğitim")</h4>
                        <p>@(isEn ? "University faculties, congress centers, dormitories and vocational schools. Including Hacettepe University's 22,000 m² Congress Center." : "Hacettepe Üniversitesi'nin 22.000 m² Kongre Merkezi dahil fakülteler, yurtlar ve meslek yüksekokulları.")</p>
                    </div>
                    <div class="hk-svc-item">
                        <span class="hk-svc-num">03</span>
                        <h4>@(isEn ? "Healthcare Infrastructure" : "Sağlık Yapıları")</h4>
                        <p>@(isEn ? "State hospitals and healthcare infrastructure to the highest safety standards — including Devrek State Hospital (22,500 m², 600 piled foundations)." : "Devrek Devlet Hastanesi (22.500 m², 600 kazıklı temel) dahil en yüksek güvenlik standartlarında devlet hastaneleri.")</p>
                    </div>
                    <div class="hk-svc-item">
                        <span class="hk-svc-num">04</span>
                        <h4>@(isEn ? "Premium Residences" : "Premium Konut")</h4>
                        <p>@(isEn ? "Luxury apartments and villa complexes in Istanbul, Tekirdağ, Bodrum and beyond — including Trakpark Premium with 42 villas." : "Trakpark Premium (42 villa) dahil İstanbul, Tekirdağ, Bodrum ve daha birçok şehirde lüks daire ve villa kompleksleri.")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── HİKAYE + TİMELİNE ────────────────────────────────── -->
<section class="hk-sec hk-sec-alt">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5 rv">
                <span class="hk-label">@(isEn ? "Our Story" : "Hikayemiz")</span>
                <h2 class="hk-h2">
                    @if (isEn) { @Html.Raw("From First Foundations<br/>to Landmark Projects") }
                    else       { @Html.Raw("İlk Temellerden<br/>İmza Projelere") }
                </h2>
                <p class="hk-lead">@(isEn
                    ? "From Safranbolu's UNESCO-listed restoration to IGA Istanbul Airport — every milestone reflects our commitment to quality and trust."
                    : "Safranbolu'nun UNESCO listesindeki tarihi konak restorasyonundan İGA İstanbul Havalimanı'na kadar her kilometre taşı kalite ve güven taahhüdümüzü yansıtır.")</p>
            </div>
            <div class="col-lg-7 rv d1">
                <div class="hk-tl">
                    <div class="hk-tl-item">
                        <div class="hk-tl-left"><span class="hk-tl-yr">1998</span></div>
                        <div class="hk-tl-spine"><div class="hk-tl-dot"></div><div class="hk-tl-bar"></div></div>
                        <div class="hk-tl-body">
                            <h5>@(isEn ? "Foundation" : "Kuruluş")</h5>
                            <p>@(isEn ? "Zonguldak Alaplı MYO and Safranbolu Fine Arts High School — our first signature projects." : "Zonguldak Alaplı MYO ve Safranbolu Güzel Sanatlar Lisesi — ilk imza projelerimiz.")</p>
                        </div>
                    </div>
                    <div class="hk-tl-item">
                        <div class="hk-tl-left"><span class="hk-tl-yr">2005</span></div>
                        <div class="hk-tl-spine"><div class="hk-tl-dot"></div><div class="hk-tl-bar"></div></div>
                        <div class="hk-tl-body">
                            <h5>@(isEn ? "Campus Expansion" : "Kampüs Büyümesi")</h5>
                            <p>@(isEn ? "Hacettepe University Congress Center (22,000 m²) and Mechanical Engineering Faculty." : "Hacettepe Üniversitesi Kongre Merkezi (22.000 m²) ve Makina Mühendisliği Fakültesi.")</p>
                        </div>
                    </div>
                    <div class="hk-tl-item">
                        <div class="hk-tl-left"><span class="hk-tl-yr">2011</span></div>
                        <div class="hk-tl-spine"><div class="hk-tl-dot"></div><div class="hk-tl-bar"></div></div>
                        <div class="hk-tl-body">
                            <h5>@(isEn ? "TOKİ & Public Health" : "TOKİ & Kamu Sağlığı")</h5>
                            <p>@(isEn ? "110 TOKİ villas in Afyonkarahisar and Devrek State Hospital (22,500 m²)." : "Afyonkarahisar'da 110 TOKİ villası ve Devrek Devlet Hastanesi (22.500 m²).")</p>
                        </div>
                    </div>
                    <div class="hk-tl-item">
                        <div class="hk-tl-left"><span class="hk-tl-yr">@(isEn ? "Now" : "Bugün")</span></div>
                        <div class="hk-tl-spine"><div class="hk-tl-dot"></div><div class="hk-tl-bar"></div></div>
                        <div class="hk-tl-body">
                            <h5>@(isEn ? "Airport & Luxury" : "Havalimanı & Lüks Konut")</h5>
                            <p>@(isEn ? "IGA Istanbul Airport and Trakpark Premium — 42-villa complex in Tekirdağ." : "İGA İstanbul Havalimanı ve Tekirdağ'da 42 villalı Trakpark Premium kompleksi.")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── MİSYON / VİZYON / DEĞERLER ───────────────────────── -->
<section class="hk-sec">
    <div class="container">
        <div class="text-center mb-5 rv">
            <span class="hk-label" style="justify-content:center;">@(isEn ? "Our Principles" : "İlkelerimiz")</span>
            <h2 class="hk-h2">@(isEn ? "What Drives Us" : "Bizi Yönlendiren Değerler")</h2>
        </div>
        <div class="hk-mvv-grid rv d1">
            <div class="hk-mvv-item">
                <h3>@(isEn ? "Mission" : "Misyon")</h3>
                <p>@(isEn
                    ? "To lead Turkey's urban transformation through safe, sustainable and high-quality construction that improves the lives of communities."
                    : "Toplulukların yaşamını iyileştiren güvenli, sürdürülebilir ve yüksek kaliteli yapılarla Türkiye'nin kentsel dönüşümüne öncülük etmek.")</p>
            </div>
            <div class="hk-mvv-item">
                <h3>@(isEn ? "Vision" : "Vizyon")</h3>
                <p>@(isEn
                    ? "To be Turkey's most trusted construction partner for public institutions and private sector — known for quality, reliability and innovation."
                    : "Kalite, güvenilirlik ve yenilikçiliğiyle tanınan; kamu ve özel sektör için Türkiye'nin en güvenilir inşaat ortağı olmak.")</p>
            </div>
            <div class="hk-mvv-item">
                <h3>@(isEn ? "Values" : "Değerler")</h3>
                <ul class="hk-values-list">
                    <li>@(isEn ? "Quality & Craftsmanship" : "Kalite ve İşçilik")</li>
                    <li>@(isEn ? "Trust & Transparency" : "Güven ve Şeffaflık")</li>
                    <li>@(isEn ? "Innovation & Sustainability" : "Yenilik ve Sürdürülebilirlik")</li>
                    <li>@(isEn ? "Customer Satisfaction" : "Müşteri Memnuniyeti")</li>
                    <li>@(isEn ? "On-Time Delivery" : "Zamanında Teslimat")</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- ── REFERANSLAR ───────────────────────────────────────── -->
@{
    var refs = ViewBag.References as List<BrikonYapi.Web.Data.Entities.Reference> ?? new List<BrikonYapi.Web.Data.Entities.Reference>();
}
<section class="hk-sec hk-sec-alt">
    <div class="container">
        <div class="text-center rv">
            <span class="hk-label">@(isEn ? "Our Partners" : "İş Ortaklarımız")</span>
            <h2 class="hk-h2">@(isEn ? "Reference Projects We Completed" : "Tamamladığımız Referans Projeler")</h2>
        </div>
    </div>
    @if (refs.Any())
    {
    <div class="hk-refs-outer rv d1">
        <div class="hk-refs-track">
            @* first pass *@
            @foreach (var r in refs)
            {
                <div class="hk-ref-chip">
                    @if (!string.IsNullOrEmpty(r.LogoPath))
                    {
                        <img src="@r.LogoPath" alt="@r.Name" loading="lazy" />
                    }
                    else
                    {
                        <span class="hk-ref-chip-name">@r.Name</span>
                    }
                </div>
            }
            @* second pass — seamless loop *@
            @foreach (var r in refs)
            {
                <div class="hk-ref-chip" aria-hidden="true">
                    @if (!string.IsNullOrEmpty(r.LogoPath))
                    {
                        <img src="@r.LogoPath" alt="@r.Name" loading="lazy" />
                    }
                    else
                    {
                        <span class="hk-ref-chip-name">@r.Name</span>
                    }
                </div>
            }
        </div>
    </div>
    }
</section>

<!-- ── CTA BAND ────────────────────────────────────────────── -->
<section class="hk-cta rv">
    <div class="container">
        <h2>@(isEn ? "Ready to Start Your Project?" : "Projenizi Hayata Geçirmeye Hazır Mısınız?")</h2>
        <p>@(isEn ? "Tell us about your idea — our team will get back within 24 hours." : "Fikrinizi bize anlatın, ekibimiz 24 saat içinde size ulaşsın.")</p>
        <button class="hk-cta-btn" id="hkContactOpen">
            @(isEn ? "Get in Touch" : "İletişime Geçin")
            <iconify-icon icon="iconamoon:arrow-right-2-bold"></iconify-icon>
        </button>
    </div>
</section>

<!-- ── İLETİŞİM MODAL ─────────────────────────────────────── -->
<div class="hk-modal-backdrop" id="hkModal" role="dialog" aria-modal="true" aria-label="@(isEn ? "Contact" : "İletişim")">
    <div class="hk-modal-box">
        <div class="hk-modal-head">
            <h3>@(isEn ? "Send us a Message" : "Mesaj Gönderin")</h3>
            <button class="hk-modal-close" id="hkModalClose" aria-label="Kapat">&times;</button>
        </div>
        <div class="hk-modal-body">
            @if (ViewBag.ContactSuccess == true)
            {
                <div class="hk-alert-ok">
                    <iconify-icon icon="iconamoon:check-circle-duotone"></iconify-icon>
                    @(isEn ? "Your message has been sent. We'll get back to you shortly." : "Mesajınız iletildi. En kısa sürede size geri döneceğiz.")
                </div>
            }
            @if (ViewBag.ContactError != null)
            {
                <div class="hk-alert-err">@ViewBag.ContactError</div>
            }
            <form class="hk-form" method="post" action="/Hakkimizda">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label">@(isEn ? "Full Name" : "Ad Soyad") *</label>
                        <input type="text" name="fullName" class="form-control" placeholder="@(isEn ? "John Doe" : "Adınız Soyadınız")" required />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">@(isEn ? "E-mail" : "E-posta") *</label>
                        <input type="email" name="email" class="form-control" placeholder="ornek@mail.com" required />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">@(isEn ? "Phone" : "Telefon")</label>
                        <input type="tel" name="phone" class="form-control" placeholder="+90 5XX XXX XX XX" />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label">@(isEn ? "Subject" : "Konu")</label>
                        <input type="text" name="subject" class="form-control" placeholder="@(isEn ? "Project inquiry" : "Proje talebi")" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">@(isEn ? "Message" : "Mesaj") *</label>
                        <textarea name="message" class="form-control" rows="5"
                            placeholder="@(isEn ? "Tell us about your project..." : "Projeniz hakkında bilgi verin...")" required></textarea>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="hk-btn-send">
                            @(isEn ? "Send Message" : "Mesaj Gönder")
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function(){
    // reveal
    var io = new IntersectionObserver(function(entries){
        entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('on'); io.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.rv').forEach(function(el){ io.observe(el); });

    // modal
    var backdrop = document.getElementById('hkModal');
    var openBtn  = document.getElementById('hkContactOpen');
    var closeBtn = document.getElementById('hkModalClose');
    var hasResult = @(ViewBag.ContactSuccess == true || ViewBag.ContactError != null ? "true" : "false");

    function openModal()  { backdrop.classList.add('open'); document.body.style.overflow = 'hidden'; }
    function closeModal() { backdrop.classList.remove('open'); document.body.style.overflow = ''; }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', function(e){ if(e.target === backdrop) closeModal(); });
    document.addEventListener('keydown', function(e){ if(e.key === 'Escape') closeModal(); });

    // auto-open on success or error (after form submit redirect)
    if(hasResult) openModal();
})();
</script>
}
