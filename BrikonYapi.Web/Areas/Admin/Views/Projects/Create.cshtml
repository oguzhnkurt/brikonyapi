@model BrikonYapi.Web.Data.Entities.Project
@using BrikonYapi.Web.Data.Entities
@{
    ViewData["Title"] = "Yeni Proje";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-xl-10">

        <div class="d-flex align-items-center mb-3 gap-2">
            <a href="/Admin/Projects" class="btn btn-sm btn-outline-secondary">
                <iconify-icon icon="iconamoon:arrow-left-2-duotone"></iconify-icon> Geri
            </a>
            <h5 class="mb-0">Yeni Proje Ekle</h5>
        </div>

        <form asp-area="Admin" asp-controller="Projects" asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Temel Bilgiler -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="card-title mb-0">Temel Bilgiler</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Proje Adı <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Lokasyon</label>
                            <input asp-for="Location" class="form-control" placeholder="İstanbul, Kadıköy" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">İlçe</label>
                            <input asp-for="District" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Şehir</label>
                            <input asp-for="City" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Durum</label>
                            <select asp-for="Status" class="form-select">
                                <option value="0">Devam Ediyor</option>
                                <option value="1">Tamamlandı</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kategori</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="">— Seçiniz —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Sıra (küçük = önce)</label>
                            <input asp-for="OrderIndex" type="number" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Proje Detayları -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="card-title mb-0">Proje Detayları</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Toplam Alan (m²)</label>
                            <input asp-for="TotalArea" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Daire Sayısı</label>
                            <input asp-for="UnitCount" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kat Sayısı</label>
                            <input asp-for="FloorCount" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Blok Sayısı</label>
                            <input asp-for="BlockCount" type="number" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">
                                Kart Etiketi
                                <small class="text-muted ms-1">— Proje kartının sağ üstünde gösterilir (örn: "42 Villa", "TOKİ", "Anahtar Teslim"). Boş bırakılırsa etiket görünmez.</small>
                            </label>
                            <input asp-for="CardTag" type="text" class="form-control" placeholder="örn: 42 Daire" maxlength="80" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Başlangıç Tarihi</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bitiş / Teslim Tarihi</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Enlem (Harita)</label>
                            <input asp-for="Latitude" type="number" step="any" class="form-control" placeholder="41.0082" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Boylam (Harita)</label>
                            <input asp-for="Longitude" type="number" step="any" class="form-control" placeholder="28.9784" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Kısa Açıklama</label>
                            <input asp-for="ShortDescription" class="form-control" placeholder="Proje listesinde görünecek kısa açıklama" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Detay Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Proje detay sayfasında görünecek tam açıklama"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Medya -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="card-title mb-0">Medya</h6></div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ana Görsel</label>
                            <input type="file" name="mainImage" class="form-control" accept="image/*" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Proje Videosu (MP4)</label>
                            <input type="file" name="projectVideo" class="form-control" accept="video/mp4,video/*" />
                            <div class="form-text">Video yüklenirse açılış ekranında arka planda oynatılır.</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Galeri -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="card-title mb-0">Galeri Görselleri</h6></div>
                <div class="card-body">
                    <label class="form-label">Görsel Ekle (çoklu seçim)</label>
                    <input type="file" name="galleryImages" class="form-control" accept="image/*" multiple />
                </div>
            </div>


            <!-- Yayın Ayarları -->
            <div class="card mb-3">
                <div class="card-header"><h6 class="card-title mb-0">Yayın Ayarları</h6></div>
                <div class="card-body">
                    <div class="d-flex gap-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label" asp-for="IsActive">Aktif</label>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                            <label class="form-check-label" asp-for="IsFeatured">
                                <iconify-icon icon="iconamoon:star-duotone" class="text-warning me-1"></iconify-icon>
                                Açılış Ekranında Göster
                            </label>
                        </div>
                        <div class="form-check form-switch">
                            <input asp-for="IsMarquee" class="form-check-input" type="checkbox" checked />
                            <label class="form-check-label" asp-for="IsMarquee">
                                <iconify-icon icon="iconamoon:play-circle-duotone" class="text-primary me-1"></iconify-icon>
                                Kayan Bantta Göster
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mb-4">
                <button type="submit" class="btn btn-primary">
                    <iconify-icon icon="iconamoon:check-duotone" class="me-1"></iconify-icon>
                    Projeyi Kaydet
                </button>
                <a href="/Admin/Projects" class="btn btn-outline-secondary">İptal</a>
            </div>

        </form>
    </div>
</div>
