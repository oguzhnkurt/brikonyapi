@{
    ViewData["Title"] = "Şifre Değiştir";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <iconify-icon icon="iconamoon:lock-duotone" class="me-2"></iconify-icon>
                    Şifre Değiştir
                </h5>
            </div>
            <div class="card-body">
                <form method="post" asp-area="Admin" asp-controller="Account" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-medium">Mevcut Şifre</label>
                        <input type="password" name="currentPassword" class="form-control" required autocomplete="current-password" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Yeni Şifre</label>
                        <input type="password" name="newPassword" class="form-control" required autocomplete="new-password"
                               placeholder="Min. 8 karakter, büyük harf ve rakam" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-medium">Yeni Şifre Tekrar</label>
                        <input type="password" name="confirmPassword" class="form-control" required autocomplete="new-password" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <iconify-icon icon="iconamoon:check-circle-1-duotone" class="me-1"></iconify-icon>
                        Şifreyi Güncelle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
