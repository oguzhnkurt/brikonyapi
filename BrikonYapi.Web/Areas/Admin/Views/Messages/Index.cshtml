@model List<BrikonYapi.Web.Data.Entities.ContactMessage>
@{
    ViewData["Title"] = "Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            İletişim Mesajları
            <span class="badge bg-secondary ms-1">@Model.Count</span>
        </h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <iconify-icon icon="iconamoon:email-duotone" class="fs-48 d-block mb-2"></iconify-icon>
                Henüz mesaj yok.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Telefon</th>
                            <th>Konu</th>
                            <th>Mesaj</th>
                            <th>Tarih</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var msg in Model)
                        {
                            <tr class="@(!msg.IsRead ? "table-primary" : "")">
                                <td>
                                    @if (!msg.IsRead)
                                    {
                                        <span class="badge bg-danger me-1" style="font-size:0.6rem">YENİ</span>
                                    }
                                    <strong>@msg.FullName</strong>
                                </td>
                                <td>
                                    <a href="mailto:@msg.Email" class="text-primary">@msg.Email</a>
                                </td>
                                <td class="text-muted">@(msg.Phone ?? "—")</td>
                                <td class="text-muted">@(msg.Subject ?? "—")</td>
                                <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" class="text-muted">
                                    @msg.Message
                                </td>
                                <td class="text-muted text-nowrap">
                                    @msg.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (!msg.IsRead)
                                        {
                                            <form asp-area="Admin" asp-controller="Messages" asp-action="MarkRead" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@msg.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <iconify-icon icon="iconamoon:check-duotone"></iconify-icon>
                                                    Okundu
                                                </button>
                                            </form>
                                        }
                                        <form asp-area="Admin" asp-controller="Messages" asp-action="Delete" method="post"
                                              onsubmit="return confirm('Mesajı sil?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@msg.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <iconify-icon icon="iconamoon:trash-duotone"></iconify-icon>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
