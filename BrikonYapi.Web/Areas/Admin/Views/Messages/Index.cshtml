@model List<BrikonYapi.Web.Data.Entities.ContactMessage>
@{
    ViewData["Title"] = "Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            İletişim Mesajları
            <span class="badge bg-secondary ms-1">@Model.Count</span>
        </h5>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">
                <iconify-icon icon="iconamoon:email-duotone" class="fs-48 d-block mb-2"></iconify-icon>
                Henüz mesaj yok.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Telefon</th>
                            <th>Konu</th>
                            <th>Mesaj</th>
                            <th>Tarih</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var msg in Model)
                        {
                            <tr class="@(!msg.IsRead ? "table-primary" : "") msg-row" style="cursor:pointer"
                                data-name="@msg.FullName"
                                data-email="@msg.Email"
                                data-phone="@(msg.Phone ?? "")"
                                data-subject="@(msg.Subject ?? "")"
                                data-message="@msg.Message"
                                data-date="@msg.CreatedAt.ToString("dd.MM.yyyy HH:mm")">
                                <td>
                                    @if (!msg.IsRead)
                                    {
                                        <span class="badge bg-danger me-1" style="font-size:0.6rem">YENİ</span>
                                    }
                                    <strong>@msg.FullName</strong>
                                </td>
                                <td>
                                    <a href="mailto:@msg.Email" class="text-primary" onclick="event.stopPropagation()">@msg.Email</a>
                                </td>
                                <td class="text-muted">@(msg.Phone ?? "—")</td>
                                <td class="text-muted">@(msg.Subject ?? "—")</td>
                                <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" class="text-muted">
                                    @msg.Message
                                </td>
                                <td class="text-muted text-nowrap">
                                    @msg.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td class="text-end" onclick="event.stopPropagation()">
                                    <div class="d-flex gap-1 justify-content-end">
                                        @if (!msg.IsRead)
                                        {
                                            <form asp-area="Admin" asp-controller="Messages" asp-action="MarkRead" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@msg.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-success">
                                                    <iconify-icon icon="iconamoon:check-duotone"></iconify-icon>
                                                    Okundu
                                                </button>
                                            </form>
                                        }
                                        <form asp-area="Admin" asp-controller="Messages" asp-action="Delete" method="post"
                                              onsubmit="return confirm('Mesajı sil?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@msg.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <iconify-icon icon="iconamoon:trash-duotone"></iconify-icon>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Gizli trigger -->
<button id="msgModalTrigger" data-bs-toggle="modal" data-bs-target="#msgModal" style="display:none"></button>

<!-- Mesaj Detay Modal -->
<div class="modal fade" id="msgModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <iconify-icon icon="iconamoon:email-duotone" class="me-2"></iconify-icon>
                    <span id="modal-name"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        <div class="text-muted small mb-1">E-posta</div>
                        <a id="modal-email" href="#" class="fw-semibold"></a>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted small mb-1">Telefon</div>
                        <div id="modal-phone" class="fw-semibold"></div>
                    </div>
                    <div class="col-sm-3">
                        <div class="text-muted small mb-1">Tarih</div>
                        <div id="modal-date" class="fw-semibold"></div>
                    </div>
                </div>
                <div class="mb-2">
                    <div class="text-muted small mb-1">Konu</div>
                    <div id="modal-subject" class="fw-semibold"></div>
                </div>
                <hr/>
                <div class="text-muted small mb-1">Mesaj</div>
                <div id="modal-message" class="p-3 bg-light rounded" style="white-space:pre-wrap;line-height:1.7"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.msg-row').forEach(function(row) {
    row.addEventListener('click', function(e) {
        if (e.target.closest('form') || e.target.closest('a')) return;
        var d = row.dataset;
        document.getElementById('modal-name').textContent = d.name;
        document.getElementById('modal-email').textContent = d.email;
        document.getElementById('modal-email').href = 'mailto:' + d.email;
        document.getElementById('modal-phone').textContent = d.phone || '—';
        document.getElementById('modal-subject').textContent = d.subject || '—';
        document.getElementById('modal-message').textContent = d.message;
        document.getElementById('modal-date').textContent = d.date;
        document.getElementById('msgModalTrigger').click();
    });
});
</script>
}
