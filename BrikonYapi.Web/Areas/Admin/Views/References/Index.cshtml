@model List<BrikonYapi.Web.Data.Entities.Reference>
@{
    ViewData["Title"] = "Referanslar";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0">Referanslar (@Model.Count)</h5>
        <a href="/Admin/References/Create" class="btn btn-primary btn-sm">
            <iconify-icon icon="iconamoon:plus-circle-duotone" class="me-1"></iconify-icon>
            Yeni Referans Ekle
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="d-flex flex-column align-items-center justify-content-center text-muted py-5">
                <iconify-icon icon="iconamoon:star-duotone" style="font-size:48px;"></iconify-icon>
                <span class="mt-2">Henüz referans eklenmemiş.</span>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:80px">Logo</th>
                            <th>Ad</th>
                            <th>Sıra</th>
                            <th>Durum</th>
                            <th>Eklenme</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.LogoPath))
                                    {
                                        <img src="@r.LogoPath" alt="@r.Name"
                                             style="height:40px;max-width:80px;object-fit:contain;background:#f5f5f5;border-radius:4px;padding:4px;" />
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center justify-content-center bg-light rounded"
                                             style="width:64px;height:40px;color:#aaa;font-size:11px">Yok</div>
                                    }
                                </td>
                                <td><strong>@r.Name</strong></td>
                                <td class="text-muted">@r.OrderIndex</td>
                                <td>
                                    @if (r.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Pasif</span>
                                    }
                                </td>
                                <td class="text-muted small">@r.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="/Admin/References/Edit/@r.Id" class="btn btn-sm btn-outline-secondary">
                                            <iconify-icon icon="iconamoon:edit-duotone"></iconify-icon>
                                            Düzenle
                                        </a>
                                        <form asp-area="Admin" asp-controller="References" asp-action="Delete" method="post" class="d-inline"
                                              onsubmit="return confirm('Bu referansı silmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <iconify-icon icon="iconamoon:trash-duotone"></iconify-icon>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
