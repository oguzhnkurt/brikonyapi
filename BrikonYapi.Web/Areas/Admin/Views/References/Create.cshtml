@model BrikonYapi.Web.Data.Entities.Reference
@{
    ViewData["Title"] = "Yeni Referans";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Yeni Referans Ekle</h5>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="References" asp-action="Create"
                      method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Referans Adı <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: TOKİ" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Logo (PNG/JPG/WebP, max 5 MB)</label>
                        <input type="file" name="logo" class="form-control" accept="image/png,image/jpeg,image/webp" />
                        <div class="form-text">Logo otomatik olarak 400px genişliğe ölçeklendirilir ve PNG olarak kaydedilir.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Sıra Numarası</label>
                        <input asp-for="OrderIndex" type="number" class="form-control" />
                        <div class="form-text">Küçük sayı önce görünür.</div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">Aktif (sitede göster)</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <iconify-icon icon="iconamoon:check-circle-1-duotone" class="me-1"></iconify-icon>
                            Kaydet
                        </button>
                        <a href="/Admin/References" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
