<!DOCTYPE html>
<html lang="tr" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Brikon Yapı Admin</title>

    <!-- Vendor CSS -->
    <link href="/admin-assets/css/vendor.min.css" rel="stylesheet" />
    <!-- Icons CSS (Boxicons) -->
    <link href="/admin-assets/css/icons.min.css" rel="stylesheet" />
    <!-- Reback App CSS -->
    <link href="/admin-assets/css/app.min.css" rel="stylesheet" />
    <!-- Theme config (required before body) -->
    <script src="/admin-assets/js/config.js"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="wrapper">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <div class="main-nav">

        <!-- Logo -->
        <div class="logo-box">
            <a href="/Admin/Dashboard" class="logo-dark">
                <img src="/images/logo-color.png" alt="Brikon Yapı" class="logo-sm" style="height:32px;max-width:120px;object-fit:contain;mix-blend-mode:multiply;" />
            </a>
            <a href="/Admin/Dashboard" class="logo-light">
                <img src="/images/logo-transparent.png" alt="Brikon Yapı" class="logo-sm" style="height:32px;max-width:120px;object-fit:contain;filter:brightness(0) invert(1);" />
            </a>
        </div>

        <!-- Collapse toggle (mini mode) -->
        <button type="button" class="button-sm-hover" aria-label="Mini sidebar">
            <iconify-icon icon="iconamoon:arrow-left-4-square-duotone" class="button-sm-hover-icon"></iconify-icon>
        </button>

        <!-- Nav items -->
        <div class="scrollbar" data-simplebar>
            <ul class="navbar-nav" id="navbar-nav">

                <li class="menu-title">Genel</li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                       href="/Admin/Dashboard">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:home-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Dashboard</span>
                    </a>
                </li>

                <li class="menu-title">İçerik</li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" ? "active" : "")"
                       href="/Admin/Projects">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:building-apartment-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Projeler</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Categories" ? "active" : "")"
                       href="/Admin/Categories">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:category-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Kategoriler</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "References" ? "active" : "")"
                       href="/Admin/References">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:star-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Referanslar</span>
                    </a>
                </li>

                <li class="menu-title">Sistem</li>

                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")"
                       href="/Admin/Settings">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:settings-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Site Ayarları</span>
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="/" target="_blank">
                        <span class="nav-icon">
                            <iconify-icon icon="iconamoon:link-external-duotone"></iconify-icon>
                        </span>
                        <span class="nav-text">Siteyi Görüntüle</span>
                    </a>
                </li>

            </ul>
        </div>
    </div>
    <!-- ═══════════════ /SIDEBAR ═══════════════ -->

    <!-- ═══════════════ TOPBAR ═══════════════ -->
    <header class="topbar">
        <div class="container-xxl">
            <div class="navbar-header">
                <div class="d-flex align-items-center gap-2">
                    <!-- Menu toggle -->
                    <div class="topbar-item">
                        <button type="button" class="button-toggle-menu">
                            <iconify-icon icon="iconamoon:menu-burger-horizontal" class="fs-22"></iconify-icon>
                        </button>
                    </div>
                    <!-- Page title -->
                    <span class="d-none d-md-block fw-semibold text-dark">@ViewData["Title"]</span>
                </div>

                <div class="d-flex align-items-center gap-1">
                    <!-- Dark mode toggle -->
                    <div class="topbar-item">
                        <button type="button" class="topbar-button" id="light-dark-mode">
                            <iconify-icon icon="iconamoon:mode-dark-duotone" class="fs-24 align-middle"></iconify-icon>
                        </button>
                    </div>

                    <!-- User dropdown -->
                    <div class="dropdown topbar-item">
                        <a type="button" class="topbar-button d-flex align-items-center gap-2"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="d-none d-md-block small fw-medium text-dark">Admin</span>
                            <span class="avatar-sm rounded-circle d-flex align-items-center justify-content-center bg-primary text-white fw-bold" style="width:32px;height:32px;font-size:13px">B</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end">
                            <h6 class="dropdown-header">Brikon Yapı</h6>
                            <div class="dropdown-divider my-1"></div>
                            <a href="/Admin/Account/ChangePassword" class="dropdown-item">
                                <iconify-icon icon="iconamoon:lock-duotone" class="fs-16 align-middle me-1"></iconify-icon>
                                Şifre Değiştir
                            </a>
                            <div class="dropdown-divider my-1"></div>
                            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="bx bx-log-out fs-18 align-middle me-1"></i>
                                    Çıkış Yap
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <!-- ═══════════════ /TOPBAR ═══════════════ -->

    <!-- ═══════════════ PAGE CONTENT ═══════════════ -->
    <div class="page-content">
        <div class="container-xxl">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    <iconify-icon icon="iconamoon:check-circle-1-duotone" class="me-2 fs-18 align-middle"></iconify-icon>
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                    <iconify-icon icon="iconamoon:close-circle-1-duotone" class="me-2 fs-18 align-middle"></iconify-icon>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </div>
    </div>
    <!-- ═══════════════ /PAGE CONTENT ═══════════════ -->

</div><!-- /wrapper -->

<!-- Vendor JS -->
<script src="/admin-assets/js/vendor.min.js"></script>
<!-- App JS -->
<script src="/admin-assets/js/app.min.js"></script>
<!-- Iconify -->
<script src="https://cdn.jsdelivr.net/npm/iconify-icon@1.0.8/dist/iconify-icon.min.js"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
