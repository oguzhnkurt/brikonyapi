@model List<BrikonYapi.Web.Data.Entities.Category>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-3">

    <!-- Kategori Listesi -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Kategoriler (@Model.Count)</h5>
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="d-flex flex-column align-items-center justify-content-center text-muted py-5">
                        <iconify-icon icon="iconamoon:category-duotone" style="font-size:48px;"></iconify-icon>
                        <span class="mt-2">Henüz kategori eklenmemiş.</span>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Kategori Adı</th>
                                    <th style="width:80px" class="text-center">Sıra</th>
                                    <th style="width:110px" class="text-center">Durum</th>
                                    <th style="width:160px" class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cat in Model)
                                {
                                    <tr id="row-@cat.Id" class="@(cat.IsActive ? "" : "table-secondary text-muted")">
                                        <td>
                                            <form asp-area="Admin" asp-controller="Categories" asp-action="Edit" method="post"
                                                  class="d-flex gap-2 align-items-center">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@cat.Id" />
                                                <input type="text" name="name" value="@cat.Name"
                                                       class="form-control form-control-sm" style="max-width:300px" required />
                                                <input type="number" name="orderIndex" value="@cat.OrderIndex"
                                                       class="form-control form-control-sm" style="width:65px" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    <iconify-icon icon="iconamoon:check-circle-1-duotone"></iconify-icon>
                                                    Kaydet
                                                </button>
                                            </form>
                                        </td>
                                        <td class="text-center small text-muted">@cat.OrderIndex</td>
                                        <td class="text-center">
                                            <form asp-area="Admin" asp-controller="Categories" asp-action="Toggle" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@cat.Id" />
                                                <div class="form-check form-switch d-flex justify-content-center m-0">
                                                    <input class="form-check-input" type="checkbox" role="switch"
                                                           @(cat.IsActive ? "checked" : "")
                                                           onchange="this.form.submit()" style="cursor:pointer; width:2.5em; height:1.3em;" />
                                                </div>
                                            </form>
                                        </td>
                                        <td class="text-end">
                                            <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" method="post" class="d-inline"
                                                  onsubmit="return confirm('@cat.Name kategorisini silmek istediğinize emin misiniz?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@cat.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <iconify-icon icon="iconamoon:trash-duotone"></iconify-icon>
                                                    Sil
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Yeni Kategori Ekle -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Yeni Kategori Ekle</h5>
            </div>
            <div class="card-body">
                <form asp-area="Admin" asp-controller="Categories" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Kategori Adı <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" placeholder="örn: Sağlık Yapıları" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Sıra (küçük = önce)</label>
                        <input type="number" name="orderIndex" class="form-control" value="0" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <iconify-icon icon="iconamoon:plus-circle-duotone" class="me-1"></iconify-icon>
                        Ekle
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>
